<Project Sdk="Microsoft.NET.Sdk">

	<!-- Shared properties -->
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<ImplicitUsings>enable</ImplicitUsings>
		<AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
		<RootNamespace>GodMode.Avalonia</RootNamespace>
	</PropertyGroup>

	<!-- Windows: full build with Voice + Windows SDK -->
	<PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
		<TargetFramework>net10.0-windows10.0.19041</TargetFramework>
		<WindowsSdkPackageVersion>10.0.19041.38</WindowsSdkPackageVersion>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<BuiltInComInteropSupport>true</BuiltInComInteropSupport>
		<DefineConstants>$(DefineConstants);VOICE_ENABLED</DefineConstants>
	</PropertyGroup>

	<!-- macOS/Linux: cross-platform, no Voice -->
	<PropertyGroup Condition="!$([MSBuild]::IsOSPlatform('Windows'))">
		<TargetFramework>net10.0</TargetFramework>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Avalonia" Version="11.3.10" />
		<PackageReference Include="Avalonia.Desktop" Version="11.3.10" />
		<PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.10" />
		<PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.10" />
		<PackageReference Include="Avalonia.Skia" Version="11.3.10" />
		<PackageReference Include="SkiaSharp" Version="3.119.1" />
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
		<PackageReference Include="System.Reactive" Version="6.1.0" />
		<PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.1" />
	</ItemGroup>

	<!-- Cross-platform project references -->
	<ItemGroup>
		<ProjectReference Include="..\GodMode.ClientBase\GodMode.ClientBase.csproj" />
		<ProjectReference Include="..\..\lib\LiquidGlassAvaloniaUI\LiquidGlassAvaloniaUI.csproj" />
	</ItemGroup>

	<!-- Voice projects: Windows only -->
	<ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
		<ProjectReference Include="..\GodMode.Voice\GodMode.Voice.csproj" />
		<ProjectReference Include="..\GodMode.Voice.Windows\GodMode.Voice.Windows.csproj" />
	</ItemGroup>

	<!-- Exclude Voice-only source files on non-Windows -->
	<ItemGroup Condition="!$([MSBuild]::IsOSPlatform('Windows'))">
		<Compile Remove="Tools\**" />
		<Compile Remove="Voice\**" />
		<Compile Remove="ViewModels\VoiceAssistantViewModel.cs" />
		<Compile Remove="Views\VoiceAssistantView.axaml.cs" />
		<AvaloniaResource Remove="Views\VoiceAssistantView.axaml" />
		<AvaloniaXaml Remove="Views\VoiceAssistantView.axaml" />
		<None Include="Views\VoiceAssistantView.axaml" />
	</ItemGroup>

</Project>
