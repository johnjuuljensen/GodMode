<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:GodMode.Avalonia.Controls"
             x:Class="GodMode.Avalonia.Controls.BashCommandView"
             x:DataType="controls:BashCommandView">

    <Border Background="{DynamicResource BgCodeBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1" CornerRadius="6"
            Padding="10,6"
            Margin="0,4">
        <StackPanel Spacing="2">
            <!-- Command with terminal prompt -->
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="$"
                           FontSize="11" FontFamily="Menlo, Consolas, monospace"
                           Foreground="{DynamicResource StateRunningBrush}" />
                <TextBlock Text="{Binding Command, RelativeSource={RelativeSource AncestorType=controls:BashCommandView}}"
                           FontSize="11" FontFamily="Menlo, Consolas, monospace"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Description subtitle -->
            <TextBlock Text="{Binding Description, RelativeSource={RelativeSource AncestorType=controls:BashCommandView}}"
                       IsVisible="{Binding Description, RelativeSource={RelativeSource AncestorType=controls:BashCommandView}, Converter={StaticResource IsNotNullConverter}}"
                       FontSize="10"
                       Foreground="{DynamicResource TextTertiaryBrush}" />
        </StackPanel>
    </Border>
</UserControl>
