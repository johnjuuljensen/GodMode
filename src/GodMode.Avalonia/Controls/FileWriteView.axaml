<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:GodMode.Avalonia.Controls"
             x:Class="GodMode.Avalonia.Controls.FileWriteView"
             x:DataType="controls:FileWriteView">

    <Border Background="{DynamicResource BgCodeBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1" CornerRadius="6"
            Margin="0,4">

        <StackPanel>
            <!-- Header -->
            <Button Padding="10,6"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    Click="ToggleExpanded">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding FilePath, RelativeSource={RelativeSource AncestorType=controls:FileWriteView}}"
                               FontSize="11" FontFamily="Menlo, Consolas, monospace"
                               Foreground="{DynamicResource AccentBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <Border Grid.Column="2"
                            Padding="6,1" CornerRadius="4"
                            Background="{DynamicResource StateRunningBrush}">
                        <TextBlock Text="Created" FontSize="9" Foreground="White" />
                    </Border>
                </Grid>
            </Button>

            <!-- Content preview -->
            <ScrollViewer IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=controls:FileWriteView}}"
                          MaxHeight="200">
                <TextBlock Text="{Binding Preview, RelativeSource={RelativeSource AncestorType=controls:FileWriteView}}"
                           FontSize="11" FontFamily="Menlo, Consolas, monospace"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Padding="10,4"
                           TextWrapping="NoWrap" />
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
