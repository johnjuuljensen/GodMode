<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- ═══════════════════════════════════════════════
             Dark Theme — macOS glass design spec
             ═══════════════════════════════════════════════ -->
        <ResourceDictionary x:Key="Dark">
            <!-- Backgrounds -->
            <Color x:Key="BgBase">#FF0E0E12</Color>
            <Color x:Key="BgSidebar">#FF121218</Color>
            <Color x:Key="BgSurface">#0BFFFFFF</Color>
            <Color x:Key="BgSurfaceHover">#14FFFFFF</Color>
            <Color x:Key="BgSurfaceActive">#1FFFFFFF</Color>
            <Color x:Key="BgElevated">#FF1A1A22</Color>
            <Color x:Key="BgInput">#0AFFFFFF</Color>
            <Color x:Key="BgOverlay">#80000000</Color>
            <Color x:Key="BgCode">#FF0A0A10</Color>

            <!-- Borders -->
            <Color x:Key="BorderSubtle">#14FFFFFF</Color>
            <Color x:Key="BorderDefault">#1FFFFFFF</Color>
            <Color x:Key="BorderStrong">#2EFFFFFF</Color>

            <!-- Text -->
            <Color x:Key="TextPrimary">#E0FFFFFF</Color>
            <Color x:Key="TextSecondary">#70FFFFFF</Color>
            <Color x:Key="TextTertiary">#38FFFFFF</Color>

            <!-- Accent -->
            <Color x:Key="Accent">#FF4F8EF7</Color>
            <Color x:Key="AccentHover">#FF6FA4F8</Color>
            <Color x:Key="AccentMuted">#1A4F8EF7</Color>

            <!-- Status -->
            <Color x:Key="StateRunning">#FF34D399</Color>
            <Color x:Key="StateWaiting">#FFFBBF24</Color>
            <Color x:Key="StateError">#FFF87171</Color>
            <Color x:Key="StateIdle">#38FFFFFF</Color>

            <!-- Message types -->
            <Color x:Key="MsgSystem">#FFA78BFA</Color>
            <Color x:Key="MsgUser">#FF4F8EF7</Color>
            <Color x:Key="MsgAssistant">#FF34D399</Color>
            <Color x:Key="MsgResult">#FFFBBF24</Color>
            <Color x:Key="MsgTool">#FFFBBF24</Color>
            <Color x:Key="MsgError">#FFF87171</Color>

            <!-- Chat bubbles — per-type -->
            <Color x:Key="BubbleUserBg">#2E4F8EF7</Color>
            <Color x:Key="BubbleUserBorder">#404F8EF7</Color>
            <Color x:Key="BubbleAssistantBg">#1F34D399</Color>
            <Color x:Key="BubbleAssistantBorder">#3334D399</Color>
            <Color x:Key="BubbleSystemBg">#1FA78BFA</Color>
            <Color x:Key="BubbleSystemBorder">#33A78BFA</Color>
            <Color x:Key="BubbleToolBg">#1AFBBF24</Color>
            <Color x:Key="BubbleToolBorder">#2EFBBF24</Color>
            <Color x:Key="BubbleErrorBg">#1FF87171</Color>
            <Color x:Key="BubbleErrorBorder">#38F87171</Color>
            <Color x:Key="BubbleDefaultBg">#0BFFFFFF</Color>
            <Color x:Key="BubbleDefaultBorder">#14FFFFFF</Color>

            <!-- Glass material colors -->
            <Color x:Key="GlassHeaderTint">#38101016</Color>
            <Color x:Key="GlassHeaderSurface">#12FFFFFF</Color>
            <Color x:Key="GlassSidebarTint">#44101016</Color>
            <Color x:Key="GlassSidebarSurface">#0AFFFFFF</Color>
            <Color x:Key="GlassModalTint">#5818181E</Color>
            <Color x:Key="GlassModalSurface">#18FFFFFF</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebar}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="BgSurfaceHoverBrush" Color="{StaticResource BgSurfaceHover}" />
            <SolidColorBrush x:Key="BgSurfaceActiveBrush" Color="{StaticResource BgSurfaceActive}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}" />
            <SolidColorBrush x:Key="BgOverlayBrush" Color="{StaticResource BgOverlay}" />
            <SolidColorBrush x:Key="BgCodeBrush" Color="{StaticResource BgCode}" />

            <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
            <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}" />
            <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}" />

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiary}" />

            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />

            <SolidColorBrush x:Key="StateRunningBrush" Color="{StaticResource StateRunning}" />
            <SolidColorBrush x:Key="StateWaitingBrush" Color="{StaticResource StateWaiting}" />
            <SolidColorBrush x:Key="StateErrorBrush" Color="{StaticResource StateError}" />
            <SolidColorBrush x:Key="StateIdleBrush" Color="{StaticResource StateIdle}" />

            <SolidColorBrush x:Key="MsgSystemBrush" Color="{StaticResource MsgSystem}" />
            <SolidColorBrush x:Key="MsgUserBrush" Color="{StaticResource MsgUser}" />
            <SolidColorBrush x:Key="MsgAssistantBrush" Color="{StaticResource MsgAssistant}" />
            <SolidColorBrush x:Key="MsgResultBrush" Color="{StaticResource MsgResult}" />
            <SolidColorBrush x:Key="MsgToolBrush" Color="{StaticResource MsgTool}" />
            <SolidColorBrush x:Key="MsgErrorBrush" Color="{StaticResource MsgError}" />

            <SolidColorBrush x:Key="BubbleUserBgBrush" Color="{StaticResource BubbleUserBg}" />
            <SolidColorBrush x:Key="BubbleUserBorderBrush" Color="{StaticResource BubbleUserBorder}" />
            <SolidColorBrush x:Key="BubbleDefaultBgBrush" Color="{StaticResource BubbleDefaultBg}" />
            <SolidColorBrush x:Key="BubbleDefaultBorderBrush" Color="{StaticResource BubbleDefaultBorder}" />
        </ResourceDictionary>

        <!-- ═══════════════════════════════════════════════
             Light Theme — macOS glass design spec
             ═══════════════════════════════════════════════ -->
        <ResourceDictionary x:Key="Light">
            <!-- Backgrounds -->
            <Color x:Key="BgBase">#FFE8EAF0</Color>
            <Color x:Key="BgSidebar">#FFF0F1F5</Color>
            <Color x:Key="BgSurface">#8CFFFFFF</Color>
            <Color x:Key="BgSurfaceHover">#B3FFFFFF</Color>
            <Color x:Key="BgSurfaceActive">#D9FFFFFF</Color>
            <Color x:Key="BgElevated">#FFFFFFFF</Color>
            <Color x:Key="BgInput">#0A000000</Color>
            <Color x:Key="BgOverlay">#59000000</Color>
            <Color x:Key="BgCode">#FFF2F3F7</Color>

            <!-- Borders -->
            <Color x:Key="BorderSubtle">#12000000</Color>
            <Color x:Key="BorderDefault">#1F000000</Color>
            <Color x:Key="BorderStrong">#2E000000</Color>

            <!-- Text -->
            <Color x:Key="TextPrimary">#E00A0A12</Color>
            <Color x:Key="TextSecondary">#750A0A12</Color>
            <Color x:Key="TextTertiary">#420A0A12</Color>

            <!-- Accent -->
            <Color x:Key="Accent">#FF2871F0</Color>
            <Color x:Key="AccentHover">#FF1A60E0</Color>
            <Color x:Key="AccentMuted">#1A2871F0</Color>

            <!-- Status -->
            <Color x:Key="StateRunning">#FF00A06A</Color>
            <Color x:Key="StateWaiting">#FFD97706</Color>
            <Color x:Key="StateError">#FFE53535</Color>
            <Color x:Key="StateIdle">#420A0A12</Color>

            <!-- Message types -->
            <Color x:Key="MsgSystem">#FF7C4DFF</Color>
            <Color x:Key="MsgUser">#FF2871F0</Color>
            <Color x:Key="MsgAssistant">#FF00A06A</Color>
            <Color x:Key="MsgResult">#FFD97706</Color>
            <Color x:Key="MsgTool">#FFD97706</Color>
            <Color x:Key="MsgError">#FFE53535</Color>

            <!-- Chat bubbles — per-type -->
            <Color x:Key="BubbleUserBg">#212871F0</Color>
            <Color x:Key="BubbleUserBorder">#382871F0</Color>
            <Color x:Key="BubbleAssistantBg">#1700A06A</Color>
            <Color x:Key="BubbleAssistantBorder">#2E00A06A</Color>
            <Color x:Key="BubbleSystemBg">#177C4DFF</Color>
            <Color x:Key="BubbleSystemBorder">#2E7C4DFF</Color>
            <Color x:Key="BubbleToolBg">#17D97706</Color>
            <Color x:Key="BubbleToolBorder">#2ED97706</Color>
            <Color x:Key="BubbleErrorBg">#17E53535</Color>
            <Color x:Key="BubbleErrorBorder">#2EE53535</Color>
            <Color x:Key="BubbleDefaultBg">#94FFFFFF</Color>
            <Color x:Key="BubbleDefaultBorder">#D1FFFFFF</Color>

            <!-- Glass material colors -->
            <Color x:Key="GlassHeaderTint">#40FFFFFF</Color>
            <Color x:Key="GlassHeaderSurface">#55FFFFFF</Color>
            <Color x:Key="GlassSidebarTint">#48FFFFFF</Color>
            <Color x:Key="GlassSidebarSurface">#48FFFFFF</Color>
            <Color x:Key="GlassModalTint">#60FFFFFF</Color>
            <Color x:Key="GlassModalSurface">#60FFFFFF</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
            <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebar}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="BgSurfaceHoverBrush" Color="{StaticResource BgSurfaceHover}" />
            <SolidColorBrush x:Key="BgSurfaceActiveBrush" Color="{StaticResource BgSurfaceActive}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}" />
            <SolidColorBrush x:Key="BgOverlayBrush" Color="{StaticResource BgOverlay}" />
            <SolidColorBrush x:Key="BgCodeBrush" Color="{StaticResource BgCode}" />

            <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
            <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}" />
            <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}" />

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiary}" />

            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />

            <SolidColorBrush x:Key="StateRunningBrush" Color="{StaticResource StateRunning}" />
            <SolidColorBrush x:Key="StateWaitingBrush" Color="{StaticResource StateWaiting}" />
            <SolidColorBrush x:Key="StateErrorBrush" Color="{StaticResource StateError}" />
            <SolidColorBrush x:Key="StateIdleBrush" Color="{StaticResource StateIdle}" />

            <SolidColorBrush x:Key="MsgSystemBrush" Color="{StaticResource MsgSystem}" />
            <SolidColorBrush x:Key="MsgUserBrush" Color="{StaticResource MsgUser}" />
            <SolidColorBrush x:Key="MsgAssistantBrush" Color="{StaticResource MsgAssistant}" />
            <SolidColorBrush x:Key="MsgResultBrush" Color="{StaticResource MsgResult}" />
            <SolidColorBrush x:Key="MsgToolBrush" Color="{StaticResource MsgTool}" />
            <SolidColorBrush x:Key="MsgErrorBrush" Color="{StaticResource MsgError}" />

            <SolidColorBrush x:Key="BubbleUserBgBrush" Color="{StaticResource BubbleUserBg}" />
            <SolidColorBrush x:Key="BubbleUserBorderBrush" Color="{StaticResource BubbleUserBorder}" />
            <SolidColorBrush x:Key="BubbleDefaultBgBrush" Color="{StaticResource BubbleDefaultBg}" />
            <SolidColorBrush x:Key="BubbleDefaultBorderBrush" Color="{StaticResource BubbleDefaultBorder}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
