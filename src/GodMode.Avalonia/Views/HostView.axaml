<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:models="using:GodMode.Shared.Models"
             x:Class="GodMode.Avalonia.Views.HostView"
             x:DataType="vm:HostViewModel">

    <Grid RowDefinitions="Auto,*" Margin="10">

        <!-- Host Status Bar -->
        <Border Grid.Row="0" Padding="15" Margin="5" Background="#2C2C2C" CornerRadius="4">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Grid.Row="0"
                           Text="{Binding HostStatus.Name}"
                           FontSize="20" FontWeight="Bold" />

                <TextBlock Grid.Column="0" Grid.Row="1"
                           Text="{Binding HostStatus.State}"
                           FontSize="16" Foreground="Gray" />

                <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal">
                    <TextBlock Text="Active Projects: " FontSize="14" />
                    <TextBlock Text="{Binding HostStatus.ProjectCount}" FontSize="14" FontWeight="Bold" />
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="3"
                            Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Content="Back"
                            Command="{Binding GoBackCommand}"
                            Width="80" />
                    <Button Content="Start"
                            Command="{Binding StartHostCommand}"
                            IsVisible="{Binding HostStatus.State, Converter={StaticResource StateToStartVisibilityConverter}}"
                            Width="80" />
                    <Button Content="Stop"
                            Command="{Binding StopHostCommand}"
                            IsVisible="{Binding HostStatus.State, Converter={StaticResource StateToStopVisibilityConverter}}"
                            Width="80" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Width="80" />
                </StackPanel>

                <!-- Connection Indicator -->
                <Ellipse Grid.Column="1" Grid.Row="2"
                         Width="12" Height="12"
                         HorizontalAlignment="Right"
                         Margin="0,5,0,0"
                         Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}" />
            </Grid>
        </Border>

        <!-- Projects -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Button Grid.Row="0"
                    Content="+ New Project"
                    Command="{Binding CreateProjectCommand}"
                    Margin="5" HorizontalAlignment="Right" />

            <ScrollViewer Grid.Row="1">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Margin="10" />

                    <ItemsControl ItemsSource="{Binding Projects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ProjectSummary">
                                <Button Margin="5" Padding="15"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding $parent[ItemsControl].((vm:HostViewModel)DataContext).NavigateToProjectCommand}"
                                        CommandParameter="{Binding .}">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Column="0" Grid.Row="0"
                                                   Text="{Binding Name}"
                                                   FontSize="18" FontWeight="Bold" />

                                        <TextBlock Grid.Column="0" Grid.Row="1"
                                                   Text="{Binding State}"
                                                   FontSize="14" Foreground="Gray" />

                                        <TextBlock Grid.Column="0" Grid.Row="2"
                                                   Text="{Binding CurrentQuestion}"
                                                   FontSize="12" Foreground="Orange"
                                                   IsVisible="{Binding CurrentQuestion, Converter={StaticResource IsNotNullConverter}}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2" />

                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding UpdatedAt, StringFormat='{}{0:HH:mm}'}"
                                                   FontSize="12" Foreground="Gray"
                                                   VerticalAlignment="Top" />

                                        <Border Grid.Column="1" Grid.Row="1"
                                                Padding="8,4"
                                                Background="{Binding State, Converter={StaticResource StateToColorConverter}}"
                                                CornerRadius="12"
                                                VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding State}"
                                                       Foreground="White" FontSize="10" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <StackPanel IsVisible="{Binding !Projects.Count}"
                                HorizontalAlignment="Center" Margin="20">
                        <TextBlock Text="No projects yet"
                                   FontSize="18" Foreground="Gray"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Create a new project to get started"
                                   FontSize="14" Foreground="Gray"
                                   HorizontalAlignment="Center" Margin="0,10,0,0" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Error -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Foreground="Red" Margin="10"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" />
    </Grid>
</UserControl>
