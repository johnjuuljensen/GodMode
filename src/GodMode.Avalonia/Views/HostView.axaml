<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:models="using:GodMode.Shared.Models"
             x:Class="GodMode.Avalonia.Views.HostView"
             x:DataType="vm:HostViewModel">

    <Grid RowDefinitions="Auto,*" Margin="16">

        <!-- Host Status Bar -->
        <Border Grid.Row="0" Padding="16" Margin="0,0,0,12"
                Background="{StaticResource CardBrush}"
                CornerRadius="{StaticResource CornerMedium}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Grid.Row="0"
                           Text="{Binding HostStatus.Name}"
                           FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold" />

                <TextBlock Grid.Column="0" Grid.Row="1"
                           Text="{Binding HostStatus.State}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,2,0,0" />

                <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Active Projects: "
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding HostStatus.ProjectCount}"
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="3"
                            Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="Back"
                            Command="{Binding GoBackCommand}"
                            Padding="12,6" FontSize="{StaticResource FontSizeSmall}" />
                    <Button Content="Start"
                            Command="{Binding StartHostCommand}"
                            IsVisible="{Binding HostStatus.State, Converter={StaticResource StateToStartVisibilityConverter}}"
                            Padding="12,6" FontSize="{StaticResource FontSizeSmall}" />
                    <Button Content="Stop"
                            Command="{Binding StopHostCommand}"
                            IsVisible="{Binding HostStatus.State, Converter={StaticResource StateToStopVisibilityConverter}}"
                            Padding="12,6" FontSize="{StaticResource FontSizeSmall}" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="12,6" FontSize="{StaticResource FontSizeSmall}" />

                    <!-- Connection Indicator -->
                    <Ellipse Width="10" Height="10"
                             VerticalAlignment="Center"
                             Margin="4,0,0,0"
                             Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Projects -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Button Grid.Row="0"
                    Content="+ New Project"
                    Command="{Binding CreateProjectCommand}"
                    Margin="0,0,0,8" HorizontalAlignment="Right"
                    Padding="12,6" FontSize="{StaticResource FontSizeBody}" />

            <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="4">
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Margin="0,8" />

                    <ItemsControl ItemsSource="{Binding Projects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ProjectSummary">
                                <Button Margin="0,2" Padding="12"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding $parent[ItemsControl].((vm:HostViewModel)DataContext).NavigateToProjectCommand}"
                                        CommandParameter="{Binding .}">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Column="0" Grid.Row="0"
                                                   Text="{Binding Name}"
                                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" />

                                        <TextBlock Grid.Column="0" Grid.Row="1"
                                                   Text="{Binding State}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{StaticResource TextMutedBrush}" />

                                        <TextBlock Grid.Column="0" Grid.Row="2"
                                                   Text="{Binding CurrentQuestion}"
                                                   FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{StaticResource HighlightBrush}"
                                                   IsVisible="{Binding CurrentQuestion, Converter={StaticResource IsNotNullConverter}}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2"
                                                   Margin="0,2,0,0" />

                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding UpdatedAt, StringFormat='{}{0:HH:mm}'}"
                                                   FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Top" />

                                        <Border Grid.Column="1" Grid.Row="1"
                                                Padding="8,3"
                                                Background="{Binding State, Converter={StaticResource StateToColorConverter}}"
                                                CornerRadius="{StaticResource CornerPill}"
                                                VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding State}"
                                                       Foreground="{StaticResource TextOnAccentBrush}"
                                                       FontSize="10" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <StackPanel IsVisible="{Binding !Projects.Count}"
                                HorizontalAlignment="Center" Margin="0,48">
                        <TextBlock Text="No projects yet"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Create a new project to get started"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{StaticResource TextSubtleBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Error -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Foreground="{StaticResource DangerBrush}" Margin="16"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" />
    </Grid>
</UserControl>
