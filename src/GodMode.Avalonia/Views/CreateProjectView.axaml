<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:views="using:GodMode.Avalonia.Views"
             xmlns:models="using:GodMode.ClientBase.Models"
             xmlns:shared="using:GodMode.Shared.Models"
             x:Class="GodMode.Avalonia.Views.CreateProjectView"
             x:DataType="vm:CreateProjectViewModel">

    <UserControl.Resources>
        <views:FormFieldTemplateSelector x:Key="FieldSelector">
            <DataTemplate x:Key="string" x:DataType="models:FormField">
                <StackPanel Spacing="5" Margin="0,5">
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" />
                    <TextBox Text="{Binding Value}" Watermark="{Binding Description}" />
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="multiline" x:DataType="models:FormField">
                <StackPanel Spacing="5" Margin="0,5">
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" />
                    <TextBox Text="{Binding Value}"
                             Watermark="{Binding Description}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="150" />
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="boolean" x:DataType="models:FormField">
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8">
                    <ToggleSwitch IsChecked="{Binding BoolValue}" />
                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Description}" VerticalAlignment="Center"
                               FontSize="12" Foreground="Gray" />
                </StackPanel>
            </DataTemplate>
        </views:FormFieldTemplateSelector>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock Text="NEW PROJECT"
                           FontSize="11" FontWeight="SemiBold"
                           LetterSpacing="1.5"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}">
                    <TextBlock.Text>
                        <Binding Path="ServerName" StringFormat="{}Server: {0}" />
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20,12" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <!-- Loading -->
                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}"
                             Height="2" />

                <!-- STEP 0: Workspace + Repo -->
                <StackPanel Spacing="10" IsVisible="{Binding IsStep0}">
                    <!-- Project Root (includes "None" option) -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="PROJECT ROOT" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <ComboBox ItemsSource="{Binding ProjectRoots}"
                                  SelectedItem="{Binding SelectedProjectRoot}"
                                  HorizontalAlignment="Stretch" FontSize="13">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="shared:ProjectRootInfo">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding Name}" FontSize="13" />
                                        <TextBlock Text="(default)" FontSize="11"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding IsDefault}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{Binding SelectedProjectRoot.Description}"
                                   FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !IsNoWorkspace}" />
                    </StackPanel>

                    <!-- Repository (only if known repos exist) -->
                    <StackPanel Spacing="4" IsVisible="{Binding HasKnownRepos}">
                        <TextBlock Text="REPOSITORY" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <ComboBox ItemsSource="{Binding KnownRepos}"
                                  SelectedItem="{Binding SelectedRepo}"
                                  HorizontalAlignment="Stretch" FontSize="13">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="shared:RepoInfo">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontSize="13" />
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}"
                                                   IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Manual repo URL -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="REPO URL (OPTIONAL)" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <TextBox Text="{Binding ManualRepoUrl}"
                                 Watermark="https://github.com/org/repo or leave blank"
                                 FontSize="13" />
                    </StackPanel>
                </StackPanel>

                <!-- STEP 1: Create (name + form fields + systems info) -->
                <StackPanel Spacing="10" IsVisible="{Binding IsStep1}">

                    <!-- Project Name (always shown) -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="PROJECT NAME" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <TextBox Text="{Binding ProjectName}"
                                 Watermark="Optional — auto-generated if blank"
                                 FontSize="13" />
                    </StackPanel>

                    <!-- Dynamic form fields (optional) -->
                    <ItemsControl ItemsSource="{Binding FormFields}"
                                  ItemTemplate="{StaticResource FieldSelector}"
                                  IsVisible="{Binding HasFormFields}" />

                    <!-- Systems info (compact, read-only) -->
                    <StackPanel Spacing="4" IsVisible="{Binding SystemMappings.Count}"
                                Margin="0,8,0,0">
                        <TextBlock Text="CREDENTIALS" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <ItemsControl ItemsSource="{Binding SystemMappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SystemMapping">
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                                        <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                                 Fill="{Binding IsResolved, Converter={StaticResource BoolToColorConverter}}" />
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                            <TextBlock.Text>
                                                <Binding Path="SystemName" StringFormat="{}{0}" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Creation Progress -->
                    <TextBlock Text="{Binding CreationProgressText}"
                               IsVisible="{Binding CreationProgressText, Converter={StaticResource IsNotNullConverter}}"
                               FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsCreating}"
                                 Height="2" />
                </StackPanel>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                           Foreground="{DynamicResource StateErrorBrush}"
                           FontSize="12" HorizontalAlignment="Center" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="20,12"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Padding="16,8"
                        FontSize="13" />
                <Button Grid.Column="1"
                        Content="Back"
                        Command="{Binding PreviousStepCommand}"
                        IsVisible="{Binding CanGoBack}"
                        HorizontalAlignment="Center"
                        Padding="16,8"
                        FontSize="13" />
                <Button Grid.Column="2"
                        Content="{Binding NextButtonText}"
                        Command="{Binding NextStepCommand}"
                        Padding="16,8"
                        FontSize="13" FontWeight="SemiBold"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
