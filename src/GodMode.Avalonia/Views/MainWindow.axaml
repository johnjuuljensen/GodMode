<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GodMode.Avalonia.ViewModels"
        x:Class="GodMode.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="GodMode - Claude Control"
        Width="1200" Height="800">
    <Grid ColumnDefinitions="*,Auto">
        <ContentControl Grid.Column="0" Content="{Binding CurrentView}" />
        <Border Grid.Column="1"
                Width="380"
                IsVisible="{Binding IsVoicePanelOpen}"
                BorderThickness="1,0,0,0">
            <ContentControl Content="{Binding Voice}" />
        </Border>
    </Grid>
</Window>
