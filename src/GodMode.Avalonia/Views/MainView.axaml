<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:models="using:GodMode.Shared.Models"
             x:Class="GodMode.Avalonia.Views.MainView"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Sidebar header: actions bar -->
        <Border Grid.Row="0" Padding="10,8"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <!-- Add Server -->
                <Button Grid.Column="0"
                        Command="{Binding AddServerCommand}"
                        ToolTip.Tip="Add Server"
                        Padding="6,4"
                        CornerRadius="6"
                        Background="{DynamicResource BgSurfaceBrush}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="+" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="Server" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Sort toggle -->
                <Button Grid.Column="1"
                        Command="{Binding ToggleSortCommand}"
                        ToolTip.Tip="Toggle sort by name / age"
                        Padding="6,4"
                        CornerRadius="6"
                        Background="{Binding SortByName, Converter={StaticResource BoolToActiveBrushConverter}}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0"
                        Margin="4,0,0,0">
                    <TextBlock Text="Az" FontSize="11" FontWeight="SemiBold" />
                </Button>

                <!-- Group by server toggle -->
                <Button Grid.Column="2"
                        Command="{Binding ToggleGroupByServerCommand}"
                        ToolTip.Tip="Toggle group by profile"
                        Padding="6,4"
                        CornerRadius="6"
                        Background="{Binding IsGroupedByServer, Converter={StaticResource BoolToActiveBrushConverter}}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0"
                        Margin="4,0,0,0">
                    <TextBlock Text="&#x2261;" FontSize="13" />
                </Button>

                <!-- Refresh -->
                <Button Grid.Column="3"
                        Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Refresh"
                        Padding="6,4"
                        CornerRadius="6"
                        Background="Transparent"
                        Foreground="{DynamicResource TextTertiaryBrush}"
                        BorderThickness="0"
                        Margin="4,0,0,0">
                    <TextBlock Text="&#x21BB;" FontSize="13" />
                </Button>
            </Grid>
        </Border>

        <!-- Loading -->
        <ProgressBar IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="2" Grid.Row="0"
                     VerticalAlignment="Bottom" />

        <!-- Profile groups + projects -->
        <ScrollViewer Grid.Row="1" Padding="4,0">
            <StackPanel>

                <!-- GROUPED view: projects under profile → root headers -->
                <ItemsControl ItemsSource="{Binding ProfileGroups}"
                              IsVisible="{Binding IsGroupedByServer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileGroupViewModel">
                            <StackPanel Margin="0,2">

                                <!-- Profile group header -->
                                <Border Padding="8,6" Background="Transparent">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <StackPanel Grid.Column="0" Grid.ColumnSpan="2"
                                                    Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ProjectCountDisplay}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,4,0" />
                                    </Grid>
                                </Border>

                                <!-- Root groups with projects -->
                                <ItemsControl ItemsSource="{Binding RootGroups}"
                                              IsVisible="{Binding IsExpanded}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RootGroupViewModel">
                                            <StackPanel>
                                                <!-- Root sub-header -->
                                                <Border Padding="20,4,8,2" Background="Transparent">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                                    VerticalAlignment="Center">
                                                            <Ellipse Width="5" Height="5"
                                                                     Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"
                                                                     VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="10" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Opacity="0.8"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <!-- Action buttons (when actions are defined) -->
                                                        <ItemsControl Grid.Column="1"
                                                                      ItemsSource="{Binding ActionItems}"
                                                                      IsVisible="{Binding HasActions}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:RootActionItem">
                                                                    <Button Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CreateProjectForRootActionCommand}"
                                                                            CommandParameter="{Binding .}"
                                                                            IsVisible="{Binding Root.IsConnected}"
                                                                            ToolTip.Tip="{Binding Action.Description}"
                                                                            Padding="5,1" FontSize="9"
                                                                            Background="{DynamicResource BgSurfaceBrush}"
                                                                            Foreground="{DynamicResource TextTertiaryBrush}"
                                                                            BorderThickness="0"
                                                                            CornerRadius="4"
                                                                            Opacity="0.9">
                                                                        <TextBlock Text="{Binding Action.Name}" FontSize="9" />
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <!-- Fallback + button (when no actions defined) -->
                                                        <Button Grid.Column="1"
                                                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CreateProjectForRootCommand}"
                                                                CommandParameter="{Binding .}"
                                                                IsVisible="{Binding !HasActions}"
                                                                ToolTip.Tip="New project"
                                                                Padding="4,1" FontSize="11"
                                                                Background="Transparent"
                                                                Foreground="{DynamicResource TextTertiaryBrush}"
                                                                BorderThickness="0"
                                                                Opacity="0.8">
                                                            <TextBlock Text="+" FontSize="11" FontWeight="SemiBold" />
                                                        </Button>
                                                    </Grid>
                                                </Border>

                                                <!-- Projects in this root -->
                                                <ItemsControl ItemsSource="{Binding Projects}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:ProjectSummary">
                                                            <Button Margin="8,1"
                                                                    Padding="10,7"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    CornerRadius="8"
                                                                    BorderThickness="0"
                                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).SelectProjectCommand}"
                                                                    CommandParameter="{Binding .}">
                                                                <Button.Background>
                                                                    <MultiBinding Converter="{StaticResource SelectedProjectBgConverter}">
                                                                        <Binding />
                                                                        <Binding Path="$parent[UserControl].((vm:MainViewModel)DataContext).SelectedProject" />
                                                                    </MultiBinding>
                                                                </Button.Background>

                                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                                    <Ellipse Grid.Column="0"
                                                                             Width="5" Height="5"
                                                                             Fill="{Binding State, Converter={StaticResource StateToColorConverter}}"
                                                                             VerticalAlignment="Center"
                                                                             Margin="0,0,8,0" />

                                                                    <StackPanel Grid.Column="1" Spacing="1" ClipToBounds="True">
                                                                        <Grid ColumnDefinitions="*,Auto">
                                                                            <TextBlock Grid.Column="0"
                                                                                       Text="{Binding Name}"
                                                                                       FontSize="13" FontWeight="Medium"
                                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                            <!-- Waiting badge -->
                                                                            <Border Grid.Column="1"
                                                                                    IsVisible="{Binding State, Converter={StaticResource ProjectStateToWaitingVisibilityConverter}}"
                                                                                    Padding="5,1" CornerRadius="4"
                                                                                    Background="#28FBBF24"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="6,0,0,0">
                                                                                <TextBlock Text="WAITING"
                                                                                           FontSize="8" FontWeight="Bold"
                                                                                           Foreground="{DynamicResource StateWaitingBrush}" />
                                                                            </Border>
                                                                        </Grid>
                                                                        <TextBlock Text="{Binding CurrentQuestion}"
                                                                                   FontSize="10"
                                                                                   Foreground="{DynamicResource StateWaitingBrush}"
                                                                                   IsVisible="{Binding CurrentQuestion, Converter={StaticResource IsNotNullConverter}}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   MaxLines="1"
                                                                                   Opacity="0.8" />
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding UpdatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                                                               FontSize="10"
                                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                                               VerticalAlignment="Top"
                                                                               Margin="4,2,0,0" />

                                                                    <!-- Delete button -->
                                                                    <Button Grid.Column="3"
                                                                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).DeleteProjectCommand}"
                                                                            CommandParameter="{Binding .}"
                                                                            ToolTip.Tip="Delete project"
                                                                            Padding="4,2"
                                                                            Background="Transparent"
                                                                            Foreground="{DynamicResource TextTertiaryBrush}"
                                                                            BorderThickness="0"
                                                                            VerticalAlignment="Center"
                                                                            Margin="4,0,0,0"
                                                                            Opacity="0.5">
                                                                        <TextBlock Text="&#x2715;" FontSize="10" />
                                                                    </Button>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- FLAT view: all projects without grouping -->
                <ItemsControl ItemsSource="{Binding ProfileGroups}"
                              IsVisible="{Binding !IsGroupedByServer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileGroupViewModel">
                            <ItemsControl ItemsSource="{Binding RootGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RootGroupViewModel">
                                        <ItemsControl ItemsSource="{Binding Projects}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:ProjectSummary">
                                                    <Button Margin="8,1"
                                                            Padding="10,7"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch"
                                                            CornerRadius="8"
                                                            BorderThickness="0"
                                                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).SelectProjectCommand}"
                                                            CommandParameter="{Binding .}">
                                                        <Button.Background>
                                                            <MultiBinding Converter="{StaticResource SelectedProjectBgConverter}">
                                                                <Binding />
                                                                <Binding Path="$parent[UserControl].((vm:MainViewModel)DataContext).SelectedProject" />
                                                            </MultiBinding>
                                                        </Button.Background>

                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                            <Ellipse Grid.Column="0"
                                                                     Width="5" Height="5"
                                                                     Fill="{Binding State, Converter={StaticResource StateToColorConverter}}"
                                                                     VerticalAlignment="Center"
                                                                     Margin="0,0,8,0" />

                                                            <StackPanel Grid.Column="1" Spacing="1" ClipToBounds="True">
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Name}"
                                                                               FontSize="13" FontWeight="Medium"
                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <!-- Waiting badge -->
                                                                    <Border Grid.Column="1"
                                                                            IsVisible="{Binding State, Converter={StaticResource ProjectStateToWaitingVisibilityConverter}}"
                                                                            Padding="5,1" CornerRadius="4"
                                                                            Background="#28FBBF24"
                                                                            VerticalAlignment="Center"
                                                                            Margin="6,0,0,0">
                                                                        <TextBlock Text="WAITING"
                                                                                   FontSize="8" FontWeight="Bold"
                                                                                   Foreground="{DynamicResource StateWaitingBrush}" />
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock Text="{Binding CurrentQuestion}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource StateWaitingBrush}"
                                                                           IsVisible="{Binding CurrentQuestion, Converter={StaticResource IsNotNullConverter}}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxLines="1"
                                                                           Opacity="0.8" />
                                                            </StackPanel>

                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding UpdatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                                       VerticalAlignment="Top"
                                                                       Margin="4,2,0,0" />

                                                            <!-- Delete button -->
                                                            <Button Grid.Column="3"
                                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).DeleteProjectCommand}"
                                                                    CommandParameter="{Binding .}"
                                                                    ToolTip.Tip="Delete project"
                                                                    Padding="4,2"
                                                                    Background="Transparent"
                                                                    Foreground="{DynamicResource TextTertiaryBrush}"
                                                                    BorderThickness="0"
                                                                    VerticalAlignment="Center"
                                                                    Margin="4,0,0,0"
                                                                    Opacity="0.5">
                                                                <TextBlock Text="&#x2715;" FontSize="10" />
                                                            </Button>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty State -->
                <StackPanel IsVisible="{Binding !Servers.Count}"
                            HorizontalAlignment="Center" Margin="20,40">
                    <TextBlock Text="No servers configured"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Add a server to get started"
                               FontSize="12"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Padding="12,6"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           FontSize="10"
                           Foreground="{DynamicResource TextTertiaryBrush}">
                    <TextBlock.Text>
                        <Binding Path="Servers.Count" StringFormat="{}{0} servers" />
                    </TextBlock.Text>
                </TextBlock>

                <!-- Hidden projects toggle -->
                <Button Grid.Column="1"
                        IsVisible="{Binding HiddenProjectCount}"
                        Command="{Binding ToggleShowHiddenCommand}"
                        Padding="4,2" FontSize="10"
                        Background="Transparent"
                        Foreground="{DynamicResource TextTertiaryBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding HiddenProjectCount, StringFormat='{}{0} hidden'}"
                                   FontSize="10" />
                        <TextBlock FontSize="10">
                            <TextBlock.Text>
                                <Binding Path="ShowHiddenProjects"
                                         Converter="{StaticResource BoolToChevronConverter}" />
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Error overlay -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Foreground="{DynamicResource StateErrorBrush}"
                   FontSize="11" Margin="12"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" />
    </Grid>
</UserControl>
