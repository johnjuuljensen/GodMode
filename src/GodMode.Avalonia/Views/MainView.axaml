<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:models="using:GodMode.Shared.Models"
             x:Class="GodMode.Avalonia.Views.MainView"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Sidebar header: actions bar -->
        <Border Grid.Row="0" Padding="10,8"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <!-- Add Server -->
                <Button Grid.Column="0"
                        Command="{Binding AddServerCommand}"
                        ToolTip.Tip="Add Server"
                        Padding="6,4"
                        CornerRadius="6"
                        Background="{DynamicResource BgSurfaceBrush}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="+" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="Server" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Group by server toggle -->
                <Button Grid.Column="1"
                        Command="{Binding ToggleGroupByServerCommand}"
                        ToolTip.Tip="Toggle group by server"
                        Padding="6,4"
                        CornerRadius="6"
                        Background="{Binding IsGroupedByServer, Converter={StaticResource BoolToActiveBrushConverter}}"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0"
                        Margin="4,0,0,0">
                    <TextBlock Text="≡" FontSize="13" />
                </Button>

                <!-- Refresh -->
                <Button Grid.Column="2"
                        Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Refresh"
                        Padding="6,4"
                        CornerRadius="6"
                        Background="Transparent"
                        Foreground="{DynamicResource TextTertiaryBrush}"
                        BorderThickness="0"
                        Margin="4,0,0,0">
                    <TextBlock Text="↻" FontSize="13" />
                </Button>
            </Grid>
        </Border>

        <!-- Loading -->
        <ProgressBar IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="2" Grid.Row="0"
                     VerticalAlignment="Bottom" />

        <!-- Server groups + projects -->
        <ScrollViewer Grid.Row="1" Padding="4,0">
            <StackPanel>

                <!-- GROUPED view: projects under server headers -->
                <ItemsControl ItemsSource="{Binding Servers}"
                              IsVisible="{Binding IsGroupedByServer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ServerGroupViewModel">
                            <StackPanel Margin="0,2">

                                <!-- Server group header -->
                                <Border Padding="8,6" Background="Transparent">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- Clickable expand/collapse area -->
                                        <Button Grid.Column="0" Grid.ColumnSpan="2"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).ToggleServerExpandedCommand}"
                                                CommandParameter="{Binding .}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <Ellipse Width="6" Height="6"
                                                         Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <!-- Server actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="3">
                                            <Border Padding="5,1"
                                                    Background="{DynamicResource AccentMutedBrush}"
                                                    CornerRadius="6"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Type}"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontSize="9" />
                                            </Border>
                                            <TextBlock Text="{Binding Projects.Count}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,2,0" />

                                            <!-- Start -->
                                            <Button Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).StartServerCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding State, Converter={StaticResource StateToStartVisibilityConverter}}"
                                                    ToolTip.Tip="Start server"
                                                    Padding="4,2" FontSize="10"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource StateRunningBrush}"
                                                    BorderThickness="0">
                                                <TextBlock Text="Start" FontSize="10" />
                                            </Button>

                                            <!-- Stop -->
                                            <Button Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).StopServerCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding State, Converter={StaticResource StateToStopVisibilityConverter}}"
                                                    ToolTip.Tip="Stop server"
                                                    Padding="4,2" FontSize="10"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource StateErrorBrush}"
                                                    BorderThickness="0">
                                                <TextBlock Text="Stop" FontSize="10" />
                                            </Button>

                                            <!-- New Project -->
                                            <Button Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CreateProjectCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsVisible="{Binding CanConnect}"
                                                    ToolTip.Tip="New project"
                                                    Padding="4,2" FontSize="12"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    BorderThickness="0">
                                                <TextBlock Text="+" FontSize="12" FontWeight="SemiBold" />
                                            </Button>

                                            <!-- Edit -->
                                            <Button Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).EditServerCommand}"
                                                    CommandParameter="{Binding .}"
                                                    ToolTip.Tip="Edit server"
                                                    Padding="4,2" FontSize="10"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource TextTertiaryBrush}"
                                                    BorderThickness="0">
                                                <TextBlock Text="Edit" FontSize="10" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Loading projects -->
                                <ProgressBar IsIndeterminate="True"
                                             IsVisible="{Binding IsLoadingProjects}"
                                             Height="2" Margin="28,0,8,4" />

                                <!-- Error -->
                                <TextBlock Text="{Binding ErrorMessage}"
                                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                                           Foreground="{DynamicResource StateErrorBrush}"
                                           FontSize="10" Margin="28,0,8,4" />

                                <!-- Projects list -->
                                <ItemsControl ItemsSource="{Binding Projects}"
                                              IsVisible="{Binding IsExpanded}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:ProjectSummary">
                                            <Button Margin="8,1"
                                                    Padding="10,7"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    CornerRadius="8"
                                                    BorderThickness="0"
                                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).SelectProjectCommand}"
                                                    CommandParameter="{Binding .}">
                                                <Button.Background>
                                                    <MultiBinding Converter="{StaticResource SelectedProjectBgConverter}">
                                                        <Binding />
                                                        <Binding Path="$parent[UserControl].((vm:MainViewModel)DataContext).SelectedProject" />
                                                    </MultiBinding>
                                                </Button.Background>

                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <Ellipse Grid.Column="0"
                                                             Width="5" Height="5"
                                                             Fill="{Binding State, Converter={StaticResource StateToColorConverter}}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,8,0" />

                                                    <StackPanel Grid.Column="1" Spacing="1">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="Medium"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <!-- Waiting badge -->
                                                            <Border IsVisible="{Binding State, Converter={StaticResource ProjectStateToWaitingVisibilityConverter}}"
                                                                    Padding="5,1" CornerRadius="4"
                                                                    Background="#28FBBF24"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="WAITING"
                                                                           FontSize="8" FontWeight="Bold"
                                                                           Foreground="{DynamicResource StateWaitingBrush}" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding CurrentQuestion}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource StateWaitingBrush}"
                                                                   IsVisible="{Binding CurrentQuestion, Converter={StaticResource IsNotNullConverter}}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxLines="1"
                                                                   Opacity="0.8" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding UpdatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               VerticalAlignment="Top"
                                                               Margin="4,2,0,0" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- FLAT view: all projects without server grouping -->
                <ItemsControl ItemsSource="{Binding Servers}"
                              IsVisible="{Binding !IsGroupedByServer}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ServerGroupViewModel">
                            <ItemsControl ItemsSource="{Binding Projects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ProjectSummary">
                                        <Button Margin="8,1"
                                                Padding="10,7"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                CornerRadius="8"
                                                BorderThickness="0"
                                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).SelectProjectCommand}"
                                                CommandParameter="{Binding .}">
                                            <Button.Background>
                                                <MultiBinding Converter="{StaticResource SelectedProjectBgConverter}">
                                                    <Binding />
                                                    <Binding Path="$parent[UserControl].((vm:MainViewModel)DataContext).SelectedProject" />
                                                </MultiBinding>
                                            </Button.Background>

                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Ellipse Grid.Column="0"
                                                         Width="5" Height="5"
                                                         Fill="{Binding State, Converter={StaticResource StateToColorConverter}}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,8,0" />

                                                <StackPanel Grid.Column="1" Spacing="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <!-- Waiting badge -->
                                                        <Border IsVisible="{Binding State, Converter={StaticResource ProjectStateToWaitingVisibilityConverter}}"
                                                                Padding="5,1" CornerRadius="4"
                                                                Background="#28FBBF24"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="WAITING"
                                                                       FontSize="8" FontWeight="Bold"
                                                                       Foreground="{DynamicResource StateWaitingBrush}" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding CurrentQuestion}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource StateWaitingBrush}"
                                                               IsVisible="{Binding CurrentQuestion, Converter={StaticResource IsNotNullConverter}}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="1"
                                                               Opacity="0.8" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding UpdatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           VerticalAlignment="Top"
                                                           Margin="4,2,0,0" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty State -->
                <StackPanel IsVisible="{Binding !Servers.Count}"
                            HorizontalAlignment="Center" Margin="20,40">
                    <TextBlock Text="No servers configured"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Add a server to get started"
                               FontSize="12"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Padding="12,6"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           FontSize="10"
                           Foreground="{DynamicResource TextTertiaryBrush}">
                    <TextBlock.Text>
                        <Binding Path="Servers.Count" StringFormat="{}{0} servers" />
                    </TextBlock.Text>
                </TextBlock>

                <!-- Hidden projects toggle -->
                <Button Grid.Column="1"
                        IsVisible="{Binding HiddenProjectCount}"
                        Command="{Binding ToggleShowHiddenCommand}"
                        Padding="4,2" FontSize="10"
                        Background="Transparent"
                        Foreground="{DynamicResource TextTertiaryBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding HiddenProjectCount, StringFormat='{}{0} hidden'}"
                                   FontSize="10" />
                        <TextBlock FontSize="10">
                            <TextBlock.Text>
                                <Binding Path="ShowHiddenProjects"
                                         Converter="{StaticResource BoolToChevronConverter}" />
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Error overlay -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Foreground="{DynamicResource StateErrorBrush}"
                   FontSize="11" Margin="12"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" />
    </Grid>
</UserControl>
