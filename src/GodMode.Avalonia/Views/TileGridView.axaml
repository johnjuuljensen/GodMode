<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:models="using:GodMode.Shared.Models"
             x:Class="GodMode.Avalonia.Views.TileGridView"
             x:DataType="vm:TileGridViewModel">

    <ScrollViewer Padding="16">
        <ItemsControl ItemsSource="{Binding Tiles}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ProjectTileViewModel">
                    <Button Margin="6"
                            Padding="0"
                            Width="320" Height="360"
                            CornerRadius="12"
                            ClipToBounds="True"
                            Background="{DynamicResource BgSurfaceBrush}"
                            BorderBrush="{Binding Summary.State, Converter={StaticResource StateToColorConverter}}"
                            BorderThickness="2"
                            Command="{Binding $parent[UserControl].((vm:TileGridViewModel)DataContext).SelectProjectCommand}"
                            CommandParameter="{Binding .}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                        <Panel>
                        <Grid RowDefinitions="Auto,*">

                            <!-- Tile header: name + state -->
                            <Border Grid.Row="0"
                                    Padding="12,10"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Ellipse Grid.Column="0"
                                             Width="8" Height="8"
                                             Fill="{Binding Summary.State, Converter={StaticResource StateToColorConverter}}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Summary.Name}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <!-- Waiting badge -->
                                        <Border IsVisible="{Binding Summary.State, Converter={StaticResource ProjectStateToWaitingVisibilityConverter}}"
                                                Padding="5,1" CornerRadius="4"
                                                Background="#28FBBF24"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="WAITING"
                                                       FontSize="8" FontWeight="Bold"
                                                       Foreground="{DynamicResource StateWaitingBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Summary.UpdatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                               FontSize="9"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </Border>

                            <!-- Miniature chat preview -->
                            <Panel Grid.Row="1" ClipToBounds="True">
                                <!-- Messages -->
                                <ItemsControl ItemsSource="{Binding Messages}"
                                              Margin="8,6"
                                              IsHitTestVisible="False">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:ClaudeMessage">
                                            <Panel Margin="0,2">
                                                <!-- Non-user: left-aligned mini bubble -->
                                                <Border IsVisible="{Binding !IsUserMessage}"
                                                        Padding="6,4"
                                                        Background="{DynamicResource BubbleDefaultBgBrush}"
                                                        CornerRadius="2,8,8,8"
                                                        MaxWidth="260"
                                                        HorizontalAlignment="Left">
                                                    <StackPanel Spacing="1">
                                                        <TextBlock Text="{Binding TypeDisplay}"
                                                                   FontSize="7" FontWeight="Bold"
                                                                   Foreground="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}" />
                                                        <TextBlock Text="{Binding ContentSummary}"
                                                                   FontSize="9"
                                                                   LineHeight="12"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"
                                                                   MaxLines="3"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>

                                                <!-- User: right-aligned mini bubble -->
                                                <Border IsVisible="{Binding IsUserMessage}"
                                                        Padding="6,4"
                                                        Background="{DynamicResource BubbleUserBgBrush}"
                                                        CornerRadius="8,8,2,8"
                                                        MaxWidth="220"
                                                        HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding ContentSummary}"
                                                               FontSize="9"
                                                               LineHeight="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap"
                                                               MaxLines="2"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </Panel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Loading indicator -->
                                <ProgressBar IsIndeterminate="True"
                                             IsVisible="{Binding IsLoadingMessages}"
                                             Height="2"
                                             VerticalAlignment="Top" />

                                <!-- Waiting question overlay at bottom -->
                                <Border IsVisible="{Binding Summary.CurrentQuestion, Converter={StaticResource IsNotNullConverter}}"
                                        VerticalAlignment="Bottom"
                                        Padding="8,6"
                                        Background="{DynamicResource StateWaitingBrush}"
                                        Opacity="0.9">
                                    <TextBlock Text="{Binding Summary.CurrentQuestion}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="#000000"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </Panel>
                        </Grid>

                        <!-- Attention icon overlay (top-right) when waiting for input -->
                        <Border IsVisible="{Binding Summary.State, Converter={StaticResource ProjectStateToWaitingVisibilityConverter}}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-4,-4,0"
                                Width="24" Height="24" CornerRadius="12"
                                Background="{DynamicResource StateWaitingBrush}"
                                ZIndex="10">
                            <TextBlock Text="?" FontSize="13" FontWeight="Bold"
                                       Foreground="#000000"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        </Panel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
