<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             x:Class="GodMode.Avalonia.Views.AddProfileView"
             x:DataType="vm:AddProfileViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Padding="20,16" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="NEW PROFILE" FontSize="11" FontWeight="SemiBold"
                       LetterSpacing="1.5" Foreground="{DynamicResource TextSecondaryBrush}" />
        </Border>

        <StackPanel Grid.Row="1" Spacing="12" Margin="20,16">
            <StackPanel Spacing="4">
                <TextBlock Text="PROFILE NAME" FontSize="10" FontWeight="SemiBold"
                           LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                <TextBox Text="{Binding ProfileName}" Watermark="Enter profile name" FontSize="13" />
                <TextBlock Text="A profile groups multiple servers together"
                           FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                       Foreground="{DynamicResource StateErrorBrush}" FontSize="12" />
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsSaving}" Height="2" />
        </StackPanel>

        <Border Grid.Row="2" Padding="20,12" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelCommand}"
                        HorizontalAlignment="Stretch" Margin="0,0,4,0" FontSize="13" />
                <Button Grid.Column="1" Content="Create" Command="{Binding SaveCommand}"
                        HorizontalAlignment="Stretch" Margin="4,0,0,0" FontSize="13" FontWeight="SemiBold"
                        Background="{DynamicResource AccentBrush}" Foreground="White" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
