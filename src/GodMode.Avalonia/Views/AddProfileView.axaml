<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             x:Class="GodMode.Avalonia.Views.AddProfileView"
             x:DataType="vm:AddProfileViewModel">

    <ScrollViewer Padding="20">
        <StackPanel Spacing="15" MaxWidth="400" HorizontalAlignment="Center">

            <!-- Profile Name -->
            <StackPanel Spacing="5">
                <TextBlock Text="Profile Name" FontWeight="Bold" />
                <TextBox Text="{Binding ProfileName}" Watermark="Enter profile name" />
                <TextBlock Text="A profile groups multiple accounts (GitHub, local folders) together"
                           FontSize="12" Foreground="Gray" />
            </StackPanel>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" Margin="0,20,0,0">
                <Button Grid.Column="0"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,5,0" />
                <Button Grid.Column="1"
                        Content="Create"
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="5,0,0,0" />
            </Grid>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                       Foreground="Red" HorizontalAlignment="Center" />

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsSaving}"
                         HorizontalAlignment="Center" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
