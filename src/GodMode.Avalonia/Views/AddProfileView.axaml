<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             x:Class="GodMode.Avalonia.Views.AddProfileView"
             x:DataType="vm:AddProfileViewModel">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="400" HorizontalAlignment="Center">

            <!-- Profile Name -->
            <StackPanel Spacing="4">
                <TextBlock Text="Profile Name" FontWeight="SemiBold"
                           FontSize="{StaticResource FontSizeBody}" />
                <TextBox Text="{Binding ProfileName}" Watermark="Enter profile name" />
                <TextBlock Text="A profile groups multiple accounts (GitHub, local folders) together"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
                <Button Grid.Column="0"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        Margin="0,0,4,0" />
                <Button Grid.Column="1"
                        Content="Create"
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        Margin="4,0,0,0" />
            </Grid>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                       Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" />

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsSaving}"
                         HorizontalAlignment="Center" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
