<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             x:Class="GodMode.Avalonia.Views.CredentialListView"
             x:DataType="vm:CredentialListViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Padding="20,16" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock Text="CREDENTIALS" FontSize="11" FontWeight="SemiBold"
                           LetterSpacing="1.5" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                           IsVisible="{Binding !IsAllProfiles}">
                    <TextBlock.Text>
                        <Binding Path="ProfileName" StringFormat="{}Profile: {0}" />
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="All profiles" FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           IsVisible="{Binding IsAllProfiles}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20,12" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <!-- Credential list -->
                <ItemsControl ItemsSource="{Binding Credentials}" IsVisible="{Binding !IsEditing}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CredentialItemViewModel">
                            <Border Padding="10,8" CornerRadius="6"
                                    Background="{DynamicResource BgSurfaceBrush}"
                                    Margin="0,2">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Type}" FontSize="10"
                                                       Foreground="{DynamicResource TextTertiaryBrush}" />
                                            <TextBlock FontSize="10"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       IsVisible="{Binding $parent[UserControl].((vm:CredentialListViewModel)DataContext).IsAllProfiles}">
                                                <TextBlock.Text>
                                                    <Binding Path="ProfileName" StringFormat="{}({0})" />
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Edit" FontSize="11"
                                            Padding="8,4" Margin="4,0"
                                            Command="{Binding $parent[UserControl].((vm:CredentialListViewModel)DataContext).StartEditCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Grid.Column="2" Content="Delete" FontSize="11"
                                            Padding="8,4"
                                            Foreground="{DynamicResource StateErrorBrush}"
                                            Command="{Binding $parent[UserControl].((vm:CredentialListViewModel)DataContext).DeleteCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No credentials stored yet"
                           IsVisible="{Binding !Credentials.Count}"
                           FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8" />

                <!-- Add button -->
                <Button Content="+ Add Credential" Command="{Binding StartAddCommand}"
                        IsVisible="{Binding !IsEditing}"
                        HorizontalAlignment="Stretch" FontSize="13"
                        HorizontalContentAlignment="Center" />

                <!-- Edit form -->
                <StackPanel Spacing="10" IsVisible="{Binding IsEditing}">
                    <!-- Profile selector (only in all-profiles mode) -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsAllProfiles}">
                        <TextBlock Text="PROFILE" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <ComboBox ItemsSource="{Binding AllProfileNames}"
                                  SelectedItem="{Binding EditProfileName}"
                                  HorizontalAlignment="Stretch" FontSize="13" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="NAME" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <TextBox Text="{Binding EditName}" Watermark="e.g. anthropic-key" FontSize="13" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <ComboBox ItemsSource="{Binding CredentialTypes}"
                                  SelectedItem="{Binding EditType}"
                                  HorizontalAlignment="Stretch" FontSize="13" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="VALUE" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <TextBox Text="{Binding EditValue}" Watermark="Enter secret value"
                                 PasswordChar="*" FontSize="13" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelEditCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,4,0" FontSize="13" />
                        <Button Grid.Column="1" Content="Save" Command="{Binding SaveEditCommand}"
                                HorizontalAlignment="Stretch" Margin="4,0,0,0" FontSize="13" FontWeight="SemiBold"
                                Background="{DynamicResource AccentBrush}" Foreground="White" />
                    </Grid>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                           Foreground="{DynamicResource StateErrorBrush}" FontSize="12" />
                <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="2" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="20,12" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
            <Button Content="Close" Command="{Binding CloseCommand}"
                    HorizontalAlignment="Stretch" FontSize="13"
                    HorizontalContentAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
