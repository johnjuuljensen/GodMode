<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:models="using:GodMode.Shared.Models"
             x:Class="GodMode.Avalonia.Views.ProjectView"
             x:DataType="vm:ProjectViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- Header Bar -->
        <Border Grid.Row="0" Padding="12" Margin="0,0,0,8"
                Background="{StaticResource CardBrush}"
                CornerRadius="{StaticResource CornerMedium}">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                <!-- State Badge -->
                <Border Grid.Column="0"
                        Padding="10,5"
                        Background="{Binding Status.State, Converter={StaticResource StateToColorConverter}}"
                        CornerRadius="{StaticResource CornerSmall}">
                    <TextBlock Text="{Binding Status.State}"
                               FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextOnAccentBrush}" />
                </Border>

                <!-- Quick Stats -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16"
                            Margin="16,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock Text="$" FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding Status.Metrics.CostEstimate, StringFormat='{}{0:F2}'}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock Text="{Binding Status.Metrics.InputTokens}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="/"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextSubtleBrush}" />
                        <TextBlock Text="{Binding Status.Metrics.OutputTokens}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text=" tok"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextSubtleBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                    <Button Content="Back"
                            Command="{Binding GoBackCommand}"
                            Padding="10,5" FontSize="{StaticResource FontSizeSmall}" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="10,5" FontSize="{StaticResource FontSizeSmall}" />
                    <Button Content="Resume"
                            Command="{Binding ResumeProjectCommand}"
                            IsVisible="{Binding CanResume}"
                            Padding="10,5" FontSize="{StaticResource FontSizeSmall}" />
                    <Button Content="Stop"
                            Command="{Binding StopProjectCommand}"
                            IsVisible="{Binding CanResume, Converter={StaticResource InverseBoolConverter}}"
                            Padding="10,5" FontSize="{StaticResource FontSizeSmall}" />
                    <Button Content="Metrics"
                            Command="{Binding LoadMetricsCommand}"
                            Padding="10,5" FontSize="{StaticResource FontSizeSmall}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chat Output -->
        <ScrollViewer Grid.Row="1" x:Name="OutputScrollViewer">
            <ItemsControl ItemsSource="{Binding OutputMessages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ClaudeMessage">
                        <Border Padding="10"
                                Margin="0,2"
                                MinWidth="80"
                                MaxWidth="900"
                                Background="{StaticResource CardInsetBrush}"
                                BorderBrush="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}"
                                BorderThickness="0,0,0,2"
                                CornerRadius="{StaticResource CornerMedium}">
                            <StackPanel Spacing="4">
                                <!-- Header: Chevron + Type Badge + Summary -->
                                <Grid ColumnDefinitions="Auto,Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                               FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSubtleBrush}" Margin="0,0,6,0"
                                               Cursor="Hand" />

                                    <Border Grid.Column="1"
                                            Padding="6,2"
                                            Background="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}"
                                            CornerRadius="{StaticResource CornerSmall}"
                                            VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding TypeDisplay}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextOnAccentBrush}" />
                                    </Border>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Summary}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" VerticalAlignment="Center"
                                               IsVisible="{Binding HasContentItems, Converter={StaticResource InverseBoolConverter}}" />
                                </Grid>

                                <!-- Collapsed: Content Summary -->
                                <TextBlock IsVisible="{Binding !IsExpanded}"
                                           Text="{Binding ContentSummary}"
                                           FontSize="{StaticResource FontSizeCaption}" FontFamily="Consolas,Courier New"
                                           Foreground="#E0E0E0"
                                           TextWrapping="Wrap"
                                           Margin="20,4,0,0" />

                                <!-- Expanded: Formatted JSON -->
                                <ScrollViewer IsVisible="{Binding IsExpanded}"
                                              MaxHeight="400" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding FormattedJson}"
                                               FontSize="10" FontFamily="Consolas,Courier New"
                                               Foreground="#E0E0E0"
                                               Background="{StaticResource CodeBlockBrush}"
                                               Padding="10"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input Area -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <Border Grid.Column="0"
                    BorderThickness="1"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    CornerRadius="{StaticResource CornerMedium}"
                    Padding="8">
                <TextBox x:Name="InputEditor"
                         Text="{Binding InputText}"
                         Watermark="Type your response..."
                         Height="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         IsEnabled="{Binding CanSendInput}" />
            </Border>

            <Button Grid.Column="1"
                    Content="Send"
                    Command="{Binding SendInputCommand}"
                    IsEnabled="{Binding CanSendInput}"
                    VerticalAlignment="Bottom"
                    Height="80" Width="80"
                    Margin="8,0,0,0"
                    FontSize="{StaticResource FontSizeBody}" />
        </Grid>

        <!-- Loading Overlay -->
        <ProgressBar Grid.Row="1"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />

        <!-- Error -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Foreground="{StaticResource DangerBrush}" Margin="16"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" />
    </Grid>
</UserControl>
