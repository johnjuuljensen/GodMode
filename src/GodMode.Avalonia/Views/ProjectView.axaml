<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:models="using:GodMode.Shared.Models"
             xmlns:controls="using:GodMode.Avalonia.Controls"
             x:Class="GodMode.Avalonia.Views.ProjectView"
             x:DataType="vm:ProjectViewModel">

    <Grid RowDefinitions="44,Auto,*,Auto,Auto">

        <!-- Project Header -->
        <Border Grid.Row="0"
                Padding="16,0"
                Background="{DynamicResource BgSidebarBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                <TextBlock Grid.Column="0"
                           Text="{Binding Status.Name, FallbackValue='Project'}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                            Margin="12,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6"
                             Fill="{Binding Status.State, Converter={StaticResource StateToColorConverter}}" />
                    <TextBlock Text="{Binding Status.State}"
                               FontSize="11"
                               Foreground="{Binding Status.State, Converter={StaticResource StateToColorConverter}}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            Margin="16,0,0,0" VerticalAlignment="Center">
                    <Border Padding="6,2" CornerRadius="4"
                            Background="{DynamicResource BgSurfaceBrush}">
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}">
                            <TextBlock.Text>
                                <Binding Path="Status.Metrics.CostEstimate" StringFormat="{}${0:F4}" FallbackValue="$0.0000" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <Border Padding="6,2" CornerRadius="4"
                            Background="{DynamicResource BgSurfaceBrush}">
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}/{1} tok">
                                    <Binding Path="Status.Metrics.InputTokens" FallbackValue="0" />
                                    <Binding Path="Status.Metrics.OutputTokens" FallbackValue="0" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                    <Button IsVisible="{Binding CanResume}"
                            Command="{Binding ResumeProjectCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource StateRunningBrush}">
                        <TextBlock Text="Resume" />
                    </Button>
                    <Button IsVisible="{Binding CanResume, Converter={StaticResource InverseBoolConverter}}"
                            Command="{Binding StopProjectCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource StateErrorBrush}">
                        <TextBlock Text="Stop" />
                    </Button>
                    <Button Command="{Binding RefreshCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource TextTertiaryBrush}">
                        <TextBlock Text="Refresh" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Attention Banner (sticky at top when question active) -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsQuestionActive}"
                Padding="12,6"
                Background="#28FBBF24"
                BorderBrush="{DynamicResource StateWaitingBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0" Width="20" Height="20" CornerRadius="10"
                        Background="{DynamicResource StateWaitingBrush}"
                        Margin="0,0,8,0">
                    <TextBlock Text="?" FontSize="11" FontWeight="Bold"
                               Foreground="#000000"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentQuestionText, FallbackValue='Waiting for your input'}"
                           FontSize="11"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1" />
                <Button Grid.Column="2" x:Name="ScrollToQuestionButton"
                        Padding="8,3" FontSize="10" CornerRadius="4"
                        Background="{DynamicResource BgSurfaceBrush}"
                        Foreground="{DynamicResource StateWaitingBrush}"
                        Margin="8,0,0,0">
                    <TextBlock Text="↓ Jump to question" FontSize="10" />
                </Button>
            </Grid>
        </Border>

        <!-- Chat Output -->
        <ScrollViewer Grid.Row="2" x:Name="OutputScrollViewer" Padding="16,8,16,0">
            <ItemsControl ItemsSource="{Binding OutputMessages}" x:Name="OutputItemsControl" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ClaudeMessage">
                        <Panel Margin="0,3">

                            <!-- Non-user message: avatar + glass bubble, left-aligned, 80% width -->
                            <Grid ColumnDefinitions="4*,*"
                                  IsVisible="{Binding !IsUserMessage}">
                                <Grid Grid.Column="0" ColumnDefinitions="Auto,*">

                                    <!-- Avatar circle with gradient -->
                                    <Border Grid.Column="0"
                                            Width="28" Height="28"
                                            CornerRadius="14"
                                            VerticalAlignment="Top"
                                            Margin="0,2,10,0"
                                            Background="{Binding Type, Converter={StaticResource MessageTypeToGradientConverter}}">
                                        <TextBlock Text="{Binding TypeInitial}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Bubble with per-type colors -->
                                    <Border Grid.Column="1"
                                            Padding="10,8"
                                            Background="{Binding Type, Converter={StaticResource MessageTypeToBgBrushConverter}}"
                                            BorderBrush="{Binding Type, Converter={StaticResource MessageTypeToBorderBrushConverter}}"
                                            BorderThickness="1"
                                            CornerRadius="4,14,14,14"
                                            HorizontalAlignment="Left">
                                        <StackPanel Spacing="2">
                                            <!-- Type + summary header -->
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding TypeDisplay}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}" />
                                                <TextBlock Text="{Binding Summary}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"
                                                           IsVisible="{Binding HasContentItems, Converter={StaticResource InverseBoolConverter}}" />
                                            </StackPanel>

                                            <!-- Message content -->
                                            <TextBlock Text="{Binding ContentSummary}"
                                                       IsVisible="{Binding !IsExpanded}"
                                                       FontSize="11.5"
                                                       LineHeight="17"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />

                                            <!-- Expanded JSON -->
                                            <ScrollViewer IsVisible="{Binding IsExpanded}"
                                                          MaxHeight="400" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding FormattedJson}"
                                                           FontSize="10" FontFamily="Menlo, Consolas, monospace"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Background="{DynamicResource BgCodeBrush}"
                                                           Padding="8"
                                                           TextWrapping="Wrap" />
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- User message: accent bubble, right-aligned, 80% width -->
                            <Grid ColumnDefinitions="*,4*"
                                  IsVisible="{Binding IsUserMessage}">
                                <Border Grid.Column="1"
                                        Padding="10,8"
                                        Background="{DynamicResource BubbleUserBgBrush}"
                                        BorderBrush="{DynamicResource BubbleUserBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14,14,4,14"
                                        HorizontalAlignment="Right">
                                    <StackPanel Spacing="2">
                                        <!-- Message content -->
                                        <TextBlock Text="{Binding ContentSummary}"
                                                   IsVisible="{Binding !IsExpanded}"
                                                   FontSize="11.5"
                                                   LineHeight="17"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" />

                                        <!-- Expanded JSON -->
                                        <ScrollViewer IsVisible="{Binding IsExpanded}"
                                                      MaxHeight="400" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding FormattedJson}"
                                                       FontSize="10" FontFamily="Menlo, Consolas, monospace"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Background="{DynamicResource BgCodeBrush}"
                                                       Padding="8"
                                                       TextWrapping="Wrap" />
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </Panel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Floating "Answer required" button when picker scrolled out of view -->
        <Button Grid.Row="2" x:Name="FloatingAnswerButton"
                IsVisible="False"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,8"
                Padding="12,6" CornerRadius="16"
                Background="{DynamicResource StateWaitingBrush}"
                Foreground="#000000"
                ZIndex="10">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Answer required" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Text="↓" FontSize="13" />
            </StackPanel>
        </Button>

        <!-- Question Prompt (visible when LLM asks a question) -->
        <controls:QuestionPromptView x:Name="QuestionPrompt"
            Grid.Row="3"
            IsVisible="{Binding IsQuestionActive}"
            Margin="16,0" />

        <!-- Input Area -->
        <Border Grid.Row="4" Padding="16,8"
                Background="{DynamicResource BgBaseBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <Border Grid.Column="0"
                        Background="{DynamicResource BgInputBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,8">
                    <TextBox x:Name="InputEditor"
                             Text="{Binding InputText}"
                             Watermark="{Binding InputWatermark}"
                             MinHeight="36"
                             MaxHeight="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsEnabled="{Binding !IsInputLocked}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="13" />
                </Border>

                <Button Grid.Column="1"
                        Command="{Binding SendInputCommand}"
                        IsEnabled="{Binding CanSendInput}"
                        VerticalAlignment="Bottom"
                        Width="32" Height="32"
                        CornerRadius="16"
                        Padding="0"
                        Margin="8,0,0,0"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White">
                    <TextBlock Text="↑" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <ProgressBar Grid.Row="2"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />

        <!-- Error -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Foreground="{DynamicResource StateErrorBrush}"
                   FontSize="11" Margin="16"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" />
    </Grid>
</UserControl>
