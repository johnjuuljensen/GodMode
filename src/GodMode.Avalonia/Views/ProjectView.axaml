<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             xmlns:models="using:GodMode.Shared.Models"
             xmlns:displayModels="using:GodMode.Avalonia.Models"
             xmlns:controls="using:GodMode.Avalonia.Controls"
             x:Class="GodMode.Avalonia.Views.ProjectView"
             x:DataType="vm:ProjectViewModel">

    <Grid RowDefinitions="44,*,Auto,Auto">

        <!-- Project Header -->
        <Border Grid.Row="0"
                Padding="16,0"
                Background="{DynamicResource BgSidebarBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                <TextBlock Grid.Column="0"
                           Text="{Binding Status.Name, FallbackValue='Project'}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                            Margin="12,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6"
                             Fill="{Binding Status.State, Converter={StaticResource StateToColorConverter}}" />
                    <TextBlock Text="{Binding Status.State}"
                               FontSize="11"
                               Foreground="{Binding Status.State, Converter={StaticResource StateToColorConverter}}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            Margin="16,0,0,0" VerticalAlignment="Center">
                    <Border Padding="6,2" CornerRadius="4"
                            Background="{DynamicResource BgSurfaceBrush}">
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}">
                            <TextBlock.Text>
                                <Binding Path="Status.Metrics.CostEstimate" StringFormat="{}${0:F4}" FallbackValue="$0.0000" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <Border Padding="6,2" CornerRadius="4"
                            Background="{DynamicResource BgSurfaceBrush}">
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}/{1} tok">
                                    <Binding Path="Status.Metrics.InputTokens" FallbackValue="0" />
                                    <Binding Path="Status.Metrics.OutputTokens" FallbackValue="0" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                    <ToggleButton IsChecked="{Binding IsSimpleView}"
                                  Padding="8,4" FontSize="11"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextTertiaryBrush}"
                                  CornerRadius="4">
                        <Panel>
                            <TextBlock Text="Simple" IsVisible="{Binding !IsSimpleView}" />
                            <TextBlock Text="Detailed" IsVisible="{Binding IsSimpleView}" />
                        </Panel>
                    </ToggleButton>
                    <Button IsVisible="{Binding CanResume}"
                            Command="{Binding ResumeProjectCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource StateRunningBrush}">
                        <TextBlock Text="Resume" />
                    </Button>
                    <Button IsVisible="{Binding CanResume, Converter={StaticResource InverseBoolConverter}}"
                            Command="{Binding StopProjectCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource StateErrorBrush}">
                        <TextBlock Text="Stop" />
                    </Button>
                    <Button Command="{Binding RefreshCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource TextTertiaryBrush}">
                        <TextBlock Text="Refresh" />
                    </Button>
                    <Button Command="{Binding LoadMetricsCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource TextTertiaryBrush}">
                        <TextBlock Text="Metrics" />
                    </Button>
                    <Button Command="{Binding DeleteProjectCommand}"
                            Padding="8,4" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource StateErrorBrush}">
                        <TextBlock Text="Delete" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chat Output with overlaid attention banner -->
        <Panel Grid.Row="1">
            <ScrollViewer x:Name="OutputScrollViewer" Padding="16,8,16,0">
                <StackPanel>
                    <!-- Load earlier messages button -->
                    <Button IsVisible="{Binding HasEarlierMessages}"
                            Command="{Binding LoadEarlierMessagesCommand}"
                            HorizontalAlignment="Center"
                            Padding="12,6" Margin="0,4,0,8"
                            Background="{DynamicResource BgSurfaceBrush}"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="0" CornerRadius="12"
                            FontSize="11">
                        <TextBlock Text="{Binding EarlierMessagesText}" />
                    </Button>

                    <ItemsControl ItemsSource="{Binding DisplayMessages}" x:Name="OutputItemsControl" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="displayModels:ChatDisplayItem">
                        <Panel Margin="0,3">

                            <!-- Tool call summary (collapsed tool calls in simple view) -->
                            <Border IsVisible="{Binding IsToolSummary}"
                                    Padding="8,4"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ToolSummaryText}"
                                           FontSize="11"
                                           FontStyle="Italic"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" />
                            </Border>

                            <!-- Regular message display -->
                            <Panel IsVisible="{Binding IsMessage}">

                                <!-- Non-user message: avatar + glass bubble, left-aligned, 80% width -->
                                <Grid ColumnDefinitions="4*,*"
                                      IsVisible="{Binding Message.IsUserMessage, Converter={StaticResource InverseBoolConverter}}">
                                    <Grid Grid.Column="0" ColumnDefinitions="Auto,*">

                                        <!-- Avatar circle with gradient -->
                                        <Border Grid.Column="0"
                                                Width="28" Height="28"
                                                CornerRadius="14"
                                                VerticalAlignment="Top"
                                                Margin="0,2,10,0"
                                                Background="{Binding Message.Type, Converter={StaticResource MessageTypeToGradientConverter}}">
                                            <TextBlock Text="{Binding Message.TypeInitial}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Bubble with per-type colors -->
                                        <Border Grid.Column="1"
                                                Padding="10,8"
                                                Background="{Binding Message.Type, Converter={StaticResource MessageTypeToBgBrushConverter}}"
                                                BorderBrush="{Binding Message.Type, Converter={StaticResource MessageTypeToBorderBrushConverter}}"
                                                BorderThickness="1"
                                                CornerRadius="4,14,14,14"
                                                HorizontalAlignment="Left">
                                            <StackPanel Spacing="2">
                                                <!-- Type + summary header -->
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding Message.TypeDisplay}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="{Binding Message.Type, Converter={StaticResource MessageTypeToColorConverter}}" />
                                                    <TextBlock Text="{Binding Message.Summary}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="1"
                                                               IsVisible="{Binding Message.HasContentItems, Converter={StaticResource InverseBoolConverter}}" />
                                                </StackPanel>

                                                <!-- Message content -->
                                                <SelectableTextBlock Text="{Binding DisplayContentSummary}"
                                                           IsVisible="{Binding Message.IsExpanded, Converter={StaticResource InverseBoolConverter}}"
                                                           FontSize="11.5"
                                                           LineHeight="17"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap" />

                                                <!-- Expanded JSON -->
                                                <ScrollViewer IsVisible="{Binding Message.IsExpanded}"
                                                              MaxHeight="400" Margin="0,4,0,0">
                                                    <SelectableTextBlock Text="{Binding Message.FormattedJson}"
                                                               FontSize="10" FontFamily="Menlo, Consolas, monospace"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Background="{DynamicResource BgCodeBrush}"
                                                               Padding="8"
                                                               TextWrapping="Wrap" />
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- User message: accent bubble, right-aligned, 80% width -->
                                <Grid ColumnDefinitions="*,4*"
                                      IsVisible="{Binding Message.IsUserMessage}">
                                    <Border Grid.Column="1"
                                            Padding="10,8"
                                            Background="{DynamicResource BubbleUserBgBrush}"
                                            BorderBrush="{DynamicResource BubbleUserBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14,14,4,14"
                                            HorizontalAlignment="Right">
                                        <StackPanel Spacing="2">
                                            <!-- Message content -->
                                            <SelectableTextBlock Text="{Binding DisplayContentSummary}"
                                                       IsVisible="{Binding Message.IsExpanded, Converter={StaticResource InverseBoolConverter}}"
                                                       FontSize="11.5"
                                                       LineHeight="17"
                                                       Foreground="{Binding HasErrorContent, Converter={StaticResource ErrorContentForegroundConverter}}"
                                                       TextWrapping="Wrap" />

                                            <!-- Expanded JSON -->
                                            <ScrollViewer IsVisible="{Binding Message.IsExpanded}"
                                                          MaxHeight="400" Margin="0,4,0,0">
                                                <SelectableTextBlock Text="{Binding Message.FormattedJson}"
                                                           FontSize="10" FontFamily="Menlo, Consolas, monospace"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Background="{DynamicResource BgCodeBrush}"
                                                           Padding="8"
                                                           TextWrapping="Wrap" />
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                            </Panel>

                        </Panel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- IC-01: Sticky attention banner at top of chat area -->
            <Border x:Name="AttentionBanner"
                    IsVisible="{Binding IsQuestionActive}"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Padding="12,8"
                    Background="{DynamicResource StateWaitingBrush}"
                    Opacity="0.95"
                    Cursor="Hand">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center">
                        <Ellipse Width="8" Height="8"
                                 Fill="#000000" Opacity="0.7" />
                        <TextBlock Text="Waiting for your input"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#000000" />
                    </StackPanel>
                    <Button x:Name="DismissBannerButton"
                            Grid.Column="1"
                            Padding="4"
                            Width="24" Height="24"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip.Tip="Dismiss (Esc)">
                        <TextBlock Text="✕"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#000000" Opacity="0.6"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- IC-04: Floating scroll-to-picker button -->
            <Button x:Name="ScrollToPickerButton"
                    IsVisible="False"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,16,8"
                    Padding="10,6"
                    CornerRadius="12"
                    Background="{DynamicResource StateWaitingBrush}"
                    Foreground="#000000"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="11" FontWeight="SemiBold">
                <TextBlock Text="Answer required ↓" />
            </Button>
        </Panel>

        <!-- Question Prompt (visible when question active AND picker not dismissed) -->
        <controls:QuestionPromptView x:Name="QuestionPrompt"
            Grid.Row="2"
            IsVisible="False"
            Margin="16,0" />

        <!-- Input Area -->
        <Border Grid.Row="3" Padding="16,8"
                Background="{DynamicResource BgBaseBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <Border Grid.Column="0"
                        Background="{DynamicResource BgInputBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,8">
                    <TextBox x:Name="InputEditor"
                             Text="{Binding InputText}"
                             Watermark="{Binding InputWatermark}"
                             MinHeight="36"
                             MaxHeight="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsEnabled="{Binding CanSendInput}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             FontSize="13" />
                </Border>

                <Button Grid.Column="1"
                        Command="{Binding SendInputCommand}"
                        IsEnabled="{Binding CanSendInput}"
                        VerticalAlignment="Bottom"
                        Width="32" Height="32"
                        CornerRadius="16"
                        Padding="0"
                        Margin="8,0,0,0"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White">
                    <TextBlock Text="↑" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <ProgressBar Grid.Row="1"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />

        <!-- Error -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Foreground="{DynamicResource StateErrorBrush}"
                   FontSize="11" Margin="16"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" />
    </Grid>
</UserControl>
