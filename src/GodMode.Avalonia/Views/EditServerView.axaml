<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             x:Class="GodMode.Avalonia.Views.EditServerView"
             x:DataType="vm:EditServerViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Padding="20,16" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock Text="EDIT SERVER" FontSize="11" FontWeight="SemiBold"
                           LetterSpacing="1.5" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}">
                    <TextBlock.Text>
                        <Binding Path="ProfileName" StringFormat="{}Profile: {0}" />
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" MaxHeight="400" Padding="20,12">
            <StackPanel Spacing="12">
                <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="2" />

                <StackPanel Spacing="4" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                    <TextBlock Text="SERVER TYPE" FontSize="10" FontWeight="SemiBold"
                               LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                    <TextBlock Text="{Binding SelectedServerType}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Spacing="10" IsVisible="{Binding IsGitHubCodespaces}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="GITHUB USERNAME" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <TextBox Text="{Binding GitHubUsername}" Watermark="Enter GitHub username" FontSize="13" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="GITHUB TOKEN" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <TextBox Text="{Binding GitHubToken}" Watermark="Enter personal access token"
                                 PasswordChar="*" FontSize="13" />
                        <TextBlock Text="Leave as ******** to keep existing token"
                                   FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="10" IsVisible="{Binding IsLocalServer}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="SERVER URL" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <TextBox Text="{Binding ServerUrl}" Watermark="http://localhost:31337" FontSize="13" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="DISPLAY NAME" FontSize="10" FontWeight="SemiBold"
                                   LetterSpacing="1" Foreground="{DynamicResource TextTertiaryBrush}" />
                        <TextBox Text="{Binding ServerDisplayName}" Watermark="Optional" FontSize="13" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                           Foreground="{DynamicResource StateErrorBrush}" FontSize="12" />
                <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsSaving}" Height="2" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="20,12" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
            <Grid ColumnDefinitions="*,Auto,*">
                <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelCommand}"
                        HorizontalAlignment="Stretch" Margin="0,0,4,0" FontSize="13" />
                <Button Grid.Column="1" Content="Delete" Command="{Binding DeleteCommand}"
                        Padding="16,8" Margin="4,0" FontSize="13"
                        Background="{DynamicResource StateErrorBrush}" Foreground="White" />
                <Button Grid.Column="2" Content="Save" Command="{Binding SaveCommand}"
                        HorizontalAlignment="Stretch" Margin="4,0,0,0" FontSize="13" FontWeight="SemiBold"
                        Background="{DynamicResource AccentBrush}" Foreground="White" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
