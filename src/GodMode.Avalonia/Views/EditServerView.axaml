<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             x:Class="GodMode.Avalonia.Views.EditServerView"
             x:DataType="vm:EditServerViewModel">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="500" HorizontalAlignment="Center">

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsLoading}"
                         HorizontalAlignment="Center" />

            <!-- Profile Info -->
            <Border Padding="12"
                    Background="{StaticResource CardBrush}"
                    CornerRadius="{StaticResource CornerMedium}"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Profile:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding ProfileName}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Server Type (read-only) -->
            <StackPanel Spacing="4" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <TextBlock Text="Server Type" FontWeight="SemiBold"
                           FontSize="{StaticResource FontSizeBody}" />
                <TextBlock Text="{Binding SelectedServerType}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>

            <!-- GitHub Fields -->
            <StackPanel Spacing="12" IsVisible="{Binding IsGitHubCodespaces}">
                <StackPanel Spacing="4">
                    <TextBlock Text="GitHub Username" FontWeight="SemiBold"
                               FontSize="{StaticResource FontSizeBody}" />
                    <TextBox Text="{Binding GitHubUsername}" Watermark="Enter GitHub username" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="GitHub Token" FontWeight="SemiBold"
                               FontSize="{StaticResource FontSizeBody}" />
                    <TextBox Text="{Binding GitHubToken}"
                             Watermark="Enter personal access token"
                             PasswordChar="*" />
                    <TextBlock Text="Leave as ******** to keep existing token, or enter a new one"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Local Server Fields -->
            <StackPanel Spacing="12" IsVisible="{Binding IsLocalServer}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Server URL" FontWeight="SemiBold"
                               FontSize="{StaticResource FontSizeBody}" />
                    <TextBox Text="{Binding ServerUrl}"
                             Watermark="http://localhost:31337" />
                    <TextBlock Text="URL of the GodMode.Server instance"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Display Name (optional)" FontWeight="SemiBold"
                               FontSize="{StaticResource FontSizeBody}" />
                    <TextBox Text="{Binding ServerDisplayName}" Watermark="Enter display name" />
                </StackPanel>
            </StackPanel>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,Auto,*" Margin="0,16,0,0"
                  IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Button Grid.Column="0"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        Margin="0,0,4,0" />
                <Button Grid.Column="1"
                        Content="Delete"
                        Command="{Binding DeleteCommand}"
                        Background="{StaticResource DangerBrush}"
                        Foreground="{StaticResource TextOnAccentBrush}"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        Margin="4,0" />
                <Button Grid.Column="2"
                        Content="Save"
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        Margin="4,0,0,0" />
            </Grid>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                       Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" />

            <!-- Saving -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsSaving}"
                         HorizontalAlignment="Center" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
