<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GodMode.Avalonia.ViewModels"
             x:Class="GodMode.Avalonia.Views.MobileMenuView"
             x:DataType="vm:MobileMenuViewModel"
             Background="{DynamicResource BgBaseBrush}">

    <ScrollViewer>
        <StackPanel Margin="0,8" Spacing="2">

            <!-- Section: General -->
            <TextBlock Text="General"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="20,12,20,6"
                       LetterSpacing="1" />

            <!-- Add Profile -->
            <Button Command="{Binding AddProfileCommand}"
                    Padding="20,14"
                    Background="Transparent"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                <Grid ColumnDefinitions="28,*">
                    <TextBlock Grid.Column="0" Text="+" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Add Profile" FontSize="14"
                               VerticalAlignment="Center" />
                </Grid>
            </Button>

            <!-- Separator -->
            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="20,8" />

            <!-- Section: Appearance -->
            <TextBlock Text="Appearance"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       Margin="20,12,20,6"
                       LetterSpacing="1" />

            <!-- Theme toggle -->
            <Button Command="{Binding ToggleThemeCommand}"
                    Padding="20,14"
                    Background="Transparent"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                <Grid ColumnDefinitions="28,*">
                    <TextBlock Grid.Column="0" Text="{Binding ThemeIcon}" FontSize="16"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Toggle Theme" FontSize="14"
                               VerticalAlignment="Center" />
                </Grid>
            </Button>

            <!-- Voice assistant -->
            <Button Command="{Binding NavigateToVoiceCommand}"
                    IsVisible="{Binding IsVoiceSupported}"
                    Padding="20,14"
                    Background="Transparent"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
                <Grid ColumnDefinitions="28,*">
                    <TextBlock Grid.Column="0" Text="&#x1f3a4;" FontSize="16"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Voice Assistant" FontSize="14"
                               VerticalAlignment="Center" />
                </Grid>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
