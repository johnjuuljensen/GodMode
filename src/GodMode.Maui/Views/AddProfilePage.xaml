<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GodMode.Maui.ViewModels"
             x:Class="GodMode.Maui.Views.AddProfilePage"
             x:DataType="viewmodels:AddProfileViewModel"
             Title="Add Profile">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15" MaximumWidthRequest="400" HorizontalOptions="Center">

            <!-- Profile Name -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Profile Name" FontAttributes="Bold" />
                <Entry Text="{Binding ProfileName}" Placeholder="Enter profile name" />
                <Label Text="A profile groups multiple accounts (GitHub, local folders) together"
                       FontSize="12"
                       TextColor="Gray" />
            </VerticalStackLayout>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" Margin="0,20,0,0">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="Gray"
                        Margin="0,0,5,0" />
                <Button Grid.Column="1"
                        Text="Create"
                        Command="{Binding SaveCommand}"
                        Margin="5,0,0,0" />
            </Grid>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="Red"
                   HorizontalTextAlignment="Center" />

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsSaving}"
                             IsVisible="{Binding IsSaving}"
                             HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
