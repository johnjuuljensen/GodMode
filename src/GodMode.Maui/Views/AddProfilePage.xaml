<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GodMode.Maui.ViewModels"
             x:Class="GodMode.Maui.Views.AddProfilePage"
             x:DataType="viewmodels:AddProfileViewModel"
             Title="Add Profile">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">

            <!-- Profile Name -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Profile Name" FontAttributes="Bold" />
                <Entry Text="{Binding ProfileName}" Placeholder="Enter profile name" />
            </VerticalStackLayout>

            <!-- Account Type Selection -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Account Type" FontAttributes="Bold" />
                <Picker ItemsSource="{Binding AccountTypes}"
                        SelectedItem="{Binding SelectedAccountType}" />
            </VerticalStackLayout>

            <!-- GitHub Account Fields -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding IsGitHubAccount}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="GitHub Username" FontAttributes="Bold" />
                    <Entry Text="{Binding GitHubUsername}" Placeholder="Enter GitHub username" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="GitHub Token" FontAttributes="Bold" />
                    <Entry Text="{Binding GitHubToken}"
                           Placeholder="Enter personal access token"
                           IsPassword="True" />
                    <Label Text="Token needs 'codespace' scope for Codespaces access"
                           FontSize="12"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Local Folder Fields -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding IsLocalAccount}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Projects Folder Path" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Grid.Column="0"
                               Text="{Binding LocalPath}"
                               Placeholder="Enter folder path" />
                        <Button Grid.Column="1"
                                Text="Browse"
                                Command="{Binding BrowseFolderCommand}"
                                Margin="5,0,0,0" />
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Display Name (optional)" FontAttributes="Bold" />
                    <Entry Text="{Binding LocalDisplayName}" Placeholder="Enter display name" />
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" Margin="0,20,0,0">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="Gray"
                        Margin="0,0,5,0" />
                <Button Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveCommand}"
                        Margin="5,0,0,0" />
            </Grid>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="Red"
                   HorizontalTextAlignment="Center" />

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsSaving}"
                             IsVisible="{Binding IsSaving}"
                             HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
