<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GodMode.Maui.ViewModels"
             xmlns:models="clr-namespace:GodMode.Shared.Models;assembly=GodMode.Shared"
             x:Class="GodMode.Maui.Views.CreateProjectPage"
             x:DataType="viewmodels:CreateProjectViewModel"
             Title="Create Project">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15" MaximumWidthRequest="600" HorizontalOptions="Center">

            <!-- Loading Indicator for initial load -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                             IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center" />

            <!-- Project Root Selection -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="Project Root" FontAttributes="Bold" />
                <Picker ItemsSource="{Binding ProjectRoots}"
                        SelectedItem="{Binding SelectedProjectRoot}"
                        ItemDisplayBinding="{Binding Name}" />
                <Label Text="Where to create the project"
                       FontSize="12"
                       TextColor="Gray" />
            </VerticalStackLayout>

            <!-- Project Type Selection -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="Project Type" FontAttributes="Bold" />
                <Picker ItemsSource="{Binding ProjectTypes}"
                        SelectedItem="{Binding SelectedProjectType}" />
                <Label Text="RawFolder: Empty project. GitHubRepo: Clone repository. GitHubWorktree: Branch-based workflow."
                       FontSize="12"
                       TextColor="Gray" />
            </VerticalStackLayout>

            <!-- Project Name -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="Project Name" FontAttributes="Bold" />
                <Entry Text="{Binding ProjectName}" Placeholder="Enter project name" />
                <Label Text="For worktree projects, this is also the branch name"
                       FontSize="12"
                       TextColor="Gray"
                       IsVisible="{Binding SelectedProjectType, Converter={StaticResource IsWorktreeConverter}}" />
            </VerticalStackLayout>

            <!-- Repository URL (required for GitHub types) -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding RequiresRepoUrl}">
                <Label Text="Repository URL" FontAttributes="Bold" />
                <Entry Text="{Binding RepoUrl}" Placeholder="https://github.com/user/repo" />
            </VerticalStackLayout>

            <!-- Initial Prompt -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="Initial Prompt" FontAttributes="Bold" />
                <Editor Text="{Binding InitialPrompt}"
                        Placeholder="Enter the initial task or prompt for Claude..."
                        HeightRequest="150" />
            </VerticalStackLayout>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" Margin="0,20,0,0" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource CancelButton}"
                        Margin="0,0,5,0" />
                <Button Grid.Column="1"
                        Text="Create"
                        Command="{Binding CreateCommand}"
                        Margin="5,0,0,0" />
            </Grid>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="Red"
                   HorizontalTextAlignment="Center" />

            <!-- Creating Indicator -->
            <ActivityIndicator IsRunning="{Binding IsCreating}"
                             IsVisible="{Binding IsCreating}"
                             HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
