<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GodMode.Maui.ViewModels"
             xmlns:models="clr-namespace:GodMode.ClientBase.Models;assembly=GodMode.ClientBase"
             x:Class="GodMode.Maui.Views.CreateProjectPage"
             x:DataType="viewmodels:CreateProjectViewModel"
             Title="Create Project">

    <ContentPage.Resources>
        <DataTemplate x:Key="StringFieldTemplate" x:DataType="models:FormField">
            <VerticalStackLayout Spacing="5" Padding="0,5">
                <Label Text="{Binding Title}" FontAttributes="Bold" />
                <Entry Text="{Binding Value}" Placeholder="{Binding Description}" />
            </VerticalStackLayout>
        </DataTemplate>

        <DataTemplate x:Key="MultilineFieldTemplate" x:DataType="models:FormField">
            <VerticalStackLayout Spacing="5" Padding="0,5">
                <Label Text="{Binding Title}" FontAttributes="Bold" />
                <Editor Text="{Binding Value}"
                        Placeholder="{Binding Description}"
                        HeightRequest="150" />
            </VerticalStackLayout>
        </DataTemplate>
    </ContentPage.Resources>

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15" MaximumWidthRequest="600" HorizontalOptions="Center">

            <!-- Loading Indicator for initial load -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                             IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center" />

            <!-- Project Root Selection -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="Project Root" FontAttributes="Bold" />
                <Picker ItemsSource="{Binding ProjectRoots}"
                        SelectedItem="{Binding SelectedProjectRoot}"
                        ItemDisplayBinding="{Binding Name}" />
                <Label Text="{Binding SelectedProjectRoot.Description}"
                       FontSize="12"
                       TextColor="Gray" />
            </VerticalStackLayout>

            <!-- Dynamic Form Fields -->
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding FormFields}"
                                 IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                 Spacing="5">
                <BindableLayout.ItemTemplateSelector>
                    <viewmodels:FormFieldTemplateSelector
                        StringTemplate="{StaticResource StringFieldTemplate}"
                        MultilineTemplate="{StaticResource MultilineFieldTemplate}" />
                </BindableLayout.ItemTemplateSelector>
            </VerticalStackLayout>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" Margin="0,20,0,0" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource CancelButton}"
                        Margin="0,0,5,0" />
                <Button Grid.Column="1"
                        Text="Create"
                        Command="{Binding CreateCommand}"
                        Margin="5,0,0,0" />
            </Grid>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="Red"
                   HorizontalTextAlignment="Center" />

            <!-- Creation Progress -->
            <Label Text="{Binding CreationProgressText}"
                   IsVisible="{Binding CreationProgressText, Converter={StaticResource IsNotNullConverter}}"
                   FontSize="12"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center" />

            <!-- Creating Indicator -->
            <ActivityIndicator IsRunning="{Binding IsCreating}"
                             IsVisible="{Binding IsCreating}"
                             HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
