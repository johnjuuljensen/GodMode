<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GodMode.Maui.ViewModels"
             xmlns:sharedmodels="clr-namespace:GodMode.Shared.Models;assembly=GodMode.Shared"
             x:Class="GodMode.Maui.Views.ProjectPage"
             x:DataType="viewmodels:ProjectViewModel"
             Title="{Binding Status.Name}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="10">

        <!-- Compact Header Bar -->
        <Border Grid.Row="0" Padding="8" Margin="5" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}" StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                <!-- State Badge -->
                <Border Grid.Column="0"
                       Padding="8,4"
                       BackgroundColor="{Binding Status.State, Converter={StaticResource StateToColorConverter}}"
                       StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="4" />
                    </Border.StrokeShape>
                    <Label Text="{Binding Status.State}"
                          FontSize="12"
                          FontAttributes="Bold"
                          TextColor="White" />
                </Border>

                <!-- Quick Stats -->
                <HorizontalStackLayout Grid.Column="1" Spacing="15" Margin="15,0,0,0" VerticalOptions="Center">
                    <Label FontSize="11" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="$" />
                                <Span Text="{Binding Status.Metrics.CostEstimate, StringFormat='{0:F2}'}" FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label FontSize="11" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding Status.Metrics.InputTokens}" />
                                <Span Text="/" />
                                <Span Text="{Binding Status.Metrics.OutputTokens}" />
                                <Span Text=" tok" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>

                <!-- Action Buttons Row -->
                <HorizontalStackLayout Grid.Column="3" Spacing="5">
                    <!-- Simple/Advanced Toggle -->
                    <Border Padding="2"
                           StrokeThickness="1"
                           Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                           HeightRequest="30">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="4" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleViewModeCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,*">
                            <Border Grid.Column="0"
                                   Padding="6,2"
                                   BackgroundColor="{Binding IsSimpleMode, Converter={StaticResource BoolToToggleColorConverter}, ConverterParameter=simple}"
                                   StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="3" />
                                </Border.StrokeShape>
                                <Label Text="Simple"
                                      FontSize="10"
                                      VerticalOptions="Center"
                                      HorizontalOptions="Center"
                                      TextColor="{Binding IsSimpleMode, Converter={StaticResource BoolToToggleTextColorConverter}, ConverterParameter=simple}" />
                            </Border>
                            <Border Grid.Column="1"
                                   Padding="6,2"
                                   BackgroundColor="{Binding IsSimpleMode, Converter={StaticResource BoolToToggleColorConverter}, ConverterParameter=advanced}"
                                   StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="3" />
                                </Border.StrokeShape>
                                <Label Text="Advanced"
                                      FontSize="10"
                                      VerticalOptions="Center"
                                      HorizontalOptions="Center"
                                      TextColor="{Binding IsSimpleMode, Converter={StaticResource BoolToToggleTextColorConverter}, ConverterParameter=advanced}" />
                            </Border>
                        </Grid>
                    </Border>
                    <Button Text="Refresh"
                           Command="{Binding RefreshCommand}"
                           FontSize="11"
                           Padding="8,4"
                           HeightRequest="30" />
                    <Button Text="Resume"
                           Command="{Binding ResumeProjectCommand}"
                           IsVisible="{Binding CanResume}"
                           FontSize="11"
                           Padding="8,4"
                           HeightRequest="30" />
                    <Button Text="Stop"
                           Command="{Binding StopProjectCommand}"
                           IsVisible="{Binding CanResume, Converter={StaticResource InverseBoolConverter}}"
                           FontSize="11"
                           Padding="8,4"
                           HeightRequest="30" />
                    <Button Text="Metrics"
                           Command="{Binding LoadMetricsCommand}"
                           FontSize="11"
                           Padding="8,4"
                           HeightRequest="30" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Chat Interface / Output Log -->
        <CollectionView Grid.Row="1"
                       x:Name="OutputCollectionView"
                       ItemsSource="{Binding OutputMessages}"
                       Margin="5">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="sharedmodels:ClaudeMessage">
                    <Grid>
                        <Border Padding="10"
                               MinimumWidthRequest="80"
                               MaximumWidthRequest="800"
                               HorizontalOptions="{Binding IsUserMessage, Converter={StaticResource IsUserToAlignmentConverter}}"
                               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                               Stroke="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}"
                               StrokeThickness="2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <!-- Type header with subtype -->
                                <Label Text="{Binding TypeDisplay}"
                                      FontSize="10"
                                      FontAttributes="Bold"
                                      TextColor="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}" />

                                <!-- Simple mode: just the content (only when VM.IsSimpleMode AND message.ShowInSimpleMode) -->
                                <Editor FontSize="12"
                                       FontFamily="Consolas"
                                       TextColor="{AppThemeBinding Light=#1E1E1E, Dark=#E0E0E0}"
                                       BackgroundColor="Transparent"
                                       IsReadOnly="True"
                                       AutoSize="TextChanges"
                                       Text="{Binding SimpleContent, Mode=OneWay}">
                                    <Editor.IsVisible>
                                        <MultiBinding Converter="{StaticResource SimpleModeMultiConverter}" ConverterParameter="simple">
                                            <Binding Path="IsSimpleMode" Source="{RelativeSource AncestorType={x:Type viewmodels:ProjectViewModel}}" />
                                            <Binding Path="ShowInSimpleMode" />
                                        </MultiBinding>
                                    </Editor.IsVisible>
                                </Editor>

                                <!-- Advanced mode: properties rendered when !VM.IsSimpleMode OR !message.ShowInSimpleMode -->
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Properties}">
                                    <VerticalStackLayout.IsVisible>
                                        <MultiBinding Converter="{StaticResource SimpleModeMultiConverter}" ConverterParameter="advanced">
                                            <Binding Path="IsSimpleMode" Source="{RelativeSource AncestorType={x:Type viewmodels:ProjectViewModel}}" />
                                            <Binding Path="ShowInSimpleMode" />
                                        </MultiBinding>
                                    </VerticalStackLayout.IsVisible>
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="sharedmodels:ClaudeMessageProperty">
                                            <Editor FontSize="12"
                                                   FontFamily="Consolas"
                                                   TextColor="{AppThemeBinding Light=#1E1E1E, Dark=#E0E0E0}"
                                                   BackgroundColor="Transparent"
                                                   IsReadOnly="True"
                                                   AutoSize="TextChanges"
                                                   Text="{Binding Display, Mode=OneWay}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="No output yet"
                          FontSize="18"
                          TextColor="Gray"
                          HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Input Area -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Padding="5">
            <Border Grid.Column="0"
                   StrokeThickness="1"
                   Stroke="{AppThemeBinding Light=LightGray, Dark=DarkGray}"
                   Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Editor x:Name="InputEditor"
                       Text="{Binding InputText}"
                       Placeholder="Type your response..."
                       HeightRequest="80"
                       IsEnabled="{Binding CanSendInput}"
                       Completed="OnInputEditorCompleted" />
            </Border>

            <Button Grid.Column="1"
                   Text="Send"
                   Command="{Binding SendInputCommand}"
                   IsEnabled="{Binding CanSendInput}"
                   VerticalOptions="End"
                   HeightRequest="80"
                   Margin="5,0,0,0"
                   WidthRequest="80" />
        </Grid>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="1"
                         IsRunning="{Binding IsLoading}"
                         IsVisible="{Binding IsLoading}"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

        <!-- Error Message -->
        <Label Grid.Row="1"
              Text="{Binding ErrorMessage}"
              IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
              TextColor="Red"
              Padding="10"
              VerticalOptions="End"
              HorizontalOptions="Center" />
    </Grid>

</ContentPage>
