<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GodMode.Maui.ViewModels"
             xmlns:sharedmodels="clr-namespace:GodMode.Shared.Models;assembly=GodMode.Shared"
             x:Class="GodMode.Maui.Views.ProjectPage"
             x:DataType="viewmodels:ProjectViewModel"
             Title="{Binding Status.Name}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="10">

        <!-- Compact Header Bar -->
        <Border Grid.Row="0" Padding="8" Margin="5" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}" StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                <!-- State Badge -->
                <Border Grid.Column="0"
                       Padding="8,4"
                       BackgroundColor="{Binding Status.State, Converter={StaticResource StateToColorConverter}}"
                       StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="4" />
                    </Border.StrokeShape>
                    <Label Text="{Binding Status.State}"
                          FontSize="12"
                          FontAttributes="Bold"
                          TextColor="White" />
                </Border>

                <!-- Quick Stats -->
                <HorizontalStackLayout Grid.Column="1" Spacing="15" Margin="15,0,0,0" VerticalOptions="Center">
                    <Label FontSize="11" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="$" />
                                <Span Text="{Binding Status.Metrics.CostEstimate, StringFormat='{0:F2}'}" FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label FontSize="11" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding Status.Metrics.InputTokens}" />
                                <Span Text="/" />
                                <Span Text="{Binding Status.Metrics.OutputTokens}" />
                                <Span Text=" tok" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>

                <!-- Action Buttons Row -->
                <HorizontalStackLayout Grid.Column="3" Spacing="5">
                    <Button Text="Refresh"
                           Command="{Binding RefreshCommand}"
                           FontSize="11"
                           Padding="8,4"
                           HeightRequest="30" />
                    <Button Text="Resume"
                           Command="{Binding ResumeProjectCommand}"
                           IsVisible="{Binding CanResume}"
                           FontSize="11"
                           Padding="8,4"
                           HeightRequest="30" />
                    <Button Text="Stop"
                           Command="{Binding StopProjectCommand}"
                           IsVisible="{Binding CanResume, Converter={StaticResource InverseBoolConverter}}"
                           FontSize="11"
                           Padding="8,4"
                           HeightRequest="30" />
                    <Button Text="Metrics"
                           Command="{Binding LoadMetricsCommand}"
                           FontSize="11"
                           Padding="8,4"
                           HeightRequest="30" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Chat Interface / Output Log -->
        <ScrollView Grid.Row="1" x:Name="OutputScrollView" Margin="5">
            <VerticalStackLayout Spacing="5"
                                BindableLayout.ItemsSource="{Binding OutputMessages}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="sharedmodels:ClaudeMessage">
                        <Border Padding="8"
                               MinimumWidthRequest="80"
                               MaximumWidthRequest="900"
                               HorizontalOptions="{Binding IsUserMessage, Converter={StaticResource IsUserToAlignmentConverter}}"
                               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                               Stroke="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}"
                               StrokeThickness="2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <!-- Header: Chevron + Type badge + Type Display -->
                                <Grid ColumnDefinitions="Auto,Auto,*">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ProjectViewModel}}, Path=ToggleMessageExpandedCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <!-- Expand Chevron -->
                                    <Label Grid.Column="0"
                                          Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                          FontSize="12"
                                          VerticalOptions="Center"
                                          TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                                          Margin="0,0,6,0" />

                                    <!-- Type Badge -->
                                    <Border Grid.Column="1"
                                           Padding="6,2"
                                           BackgroundColor="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}"
                                           StrokeThickness="0"
                                           VerticalOptions="Center"
                                           Margin="0,0,8,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="3" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding TypeDisplay}"
                                              FontSize="10"
                                              FontAttributes="Bold"
                                              TextColor="White" />
                                    </Border>

                                    <!-- Summary text for non-content-item messages (system, result) -->
                                    <Label Grid.Column="2"
                                          Text="{Binding Summary}"
                                          FontSize="11"
                                          TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}"
                                          LineBreakMode="TailTruncation"
                                          MaxLines="1"
                                          VerticalOptions="Center"
                                          IsVisible="{Binding HasContentItems, Converter={StaticResource InverseBoolConverter}}" />
                                </Grid>

                                <!-- Collapsed View: Content Summary -->
                                <Label IsVisible="{Binding IsExpanded, Converter={StaticResource InverseBoolConverter}}"
                                      Text="{Binding ContentSummary}"
                                      FontSize="11"
                                      FontFamily="Consolas"
                                      TextColor="{AppThemeBinding Light=#1E1E1E, Dark=#E0E0E0}"
                                      LineBreakMode="WordWrap"
                                      Margin="20,4,0,0" />

                                <!-- Expanded View: Formatted JSON -->
                                <ScrollView IsVisible="{Binding IsExpanded}"
                                           MaximumHeightRequest="400"
                                           Margin="0,4,0,0">
                                    <Label Text="{Binding FormattedJson}"
                                          FontSize="10"
                                          FontFamily="Consolas"
                                          TextColor="{AppThemeBinding Light=#1E1E1E, Dark=#E0E0E0}"
                                          BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0D0D0D}"
                                          Padding="8" />
                                </ScrollView>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Input Area -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Padding="5">
            <Border Grid.Column="0"
                   StrokeThickness="1"
                   Stroke="{AppThemeBinding Light=LightGray, Dark=DarkGray}"
                   Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Editor x:Name="InputEditor"
                       Text="{Binding InputText}"
                       Placeholder="Type your response..."
                       HeightRequest="80"
                       IsEnabled="{Binding CanSendInput}"
                       Completed="OnInputEditorCompleted" />
            </Border>

            <Button Grid.Column="1"
                   Text="Send"
                   Command="{Binding SendInputCommand}"
                   IsEnabled="{Binding CanSendInput}"
                   VerticalOptions="End"
                   HeightRequest="80"
                   Margin="5,0,0,0"
                   WidthRequest="80" />
        </Grid>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="1"
                         IsRunning="{Binding IsLoading}"
                         IsVisible="{Binding IsLoading}"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

        <!-- Error Message -->
        <Label Grid.Row="1"
              Text="{Binding ErrorMessage}"
              IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
              TextColor="Red"
              Padding="10"
              VerticalOptions="End"
              HorizontalOptions="Center" />
    </Grid>

</ContentPage>
