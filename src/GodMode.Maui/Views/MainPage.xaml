<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GodMode.Maui.ViewModels"
             xmlns:models="clr-namespace:GodMode.Shared.Models;assembly=GodMode.Shared"
             x:Class="GodMode.Maui.Views.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="GodMode - Claude Control">

    <Grid RowDefinitions="Auto,*" Padding="10">

        <!-- Profile Selector -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Padding="10" Margin="0,0,0,10">
            <Picker Grid.Column="0"
                    Title="Select Profile"
                    ItemsSource="{Binding Profiles}"
                    SelectedItem="{Binding SelectedProfile}"
                    ItemDisplayBinding="{Binding Name}"
                    HorizontalOptions="Fill" />

            <Button Grid.Column="1"
                    Text="+ Server"
                    Command="{Binding AddServerCommand}"
                    Margin="10,0,0,0"
                    IsVisible="{Binding SelectedProfile, Converter={StaticResource IsNotNullConverter}}" />

            <Button Grid.Column="2"
                    Text="+ Profile"
                    Command="{Binding AddProfileCommand}"
                    Margin="5,0,0,0" />
        </Grid>

        <!-- Hosts List -->
        <Grid Grid.Row="1">
            <RefreshView IsRefreshing="{Binding IsLoading}"
                        Command="{Binding RefreshHostsCommand}">
                <CollectionView ItemsSource="{Binding Hosts}"
                               SelectionMode="Single">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:HostInfo">
                            <Border Padding="15"
                                   Margin="5"
                                   Stroke="{AppThemeBinding Light=LightGray, Dark=DarkGray}"
                                   StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=NavigateToHostCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Column="0" Grid.Row="0"
                                          Text="{Binding Name}"
                                          FontSize="18"
                                          FontAttributes="Bold" />

                                    <Label Grid.Column="0" Grid.Row="1"
                                          Text="{Binding State}"
                                          FontSize="14"
                                          TextColor="Gray" />

                                    <Label Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                                          Text="{Binding Type}"
                                          FontSize="12"
                                          TextColor="White"
                                          BackgroundColor="#512BD4"
                                          Padding="8,4"
                                          VerticalOptions="Center"
                                          HorizontalOptions="End" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="No hosts available"
                                  FontSize="18"
                                  TextColor="Gray"
                                  HorizontalTextAlignment="Center" />
                            <Label Text="Add a server to your profile to get started"
                                  FontSize="14"
                                  TextColor="Gray"
                                  HorizontalTextAlignment="Center"
                                  Margin="0,10,0,0" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </RefreshView>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                             IsVisible="{Binding IsLoading}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
        </Grid>

        <!-- Error Message -->
        <Label Grid.Row="1"
              Text="{Binding ErrorMessage}"
              IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
              TextColor="Red"
              Padding="10"
              VerticalOptions="End"
              HorizontalOptions="Center" />
    </Grid>

</ContentPage>
