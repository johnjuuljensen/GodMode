<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:GodMode.Maui.ViewModels"
             xmlns:models="clr-namespace:GodMode.Shared.Models;assembly=GodMode.Shared"
             x:Class="GodMode.Maui.Views.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="GodMode">

    <Grid RowDefinitions="Auto,*" Padding="10">

        <!-- Header: Profile Selector and Actions -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Padding="10" Margin="0,0,0,10">
            <Picker Grid.Column="0"
                    Title="Select Profile"
                    ItemsSource="{Binding ProfileOptions}"
                    SelectedItem="{Binding SelectedProfileOption}"
                    ItemDisplayBinding="{Binding Name}"
                    HorizontalOptions="Fill" />

            <Button Grid.Column="1"
                    Text="+ Server"
                    Command="{Binding AddServerCommand}"
                    Margin="10,0,0,0" />

            <Button Grid.Column="2"
                    Text="+ Profile"
                    Command="{Binding AddProfileCommand}"
                    Margin="5,0,0,0" />
        </Grid>

        <!-- Servers List with Nested Projects -->
        <RefreshView Grid.Row="1"
                    IsRefreshing="{Binding IsLoading}"
                    Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Servers}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:ServerGroupViewModel">
                        <VerticalStackLayout Margin="5">
                            <!-- Server Header -->
                            <Border Padding="12"
                                   BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2C}"
                                   StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8,8,0,0" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=ToggleServerExpandedCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto,Auto">
                                    <!-- Expand/Collapse Indicator -->
                                    <Label Grid.Column="0" Grid.RowSpan="2"
                                          Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                          FontSize="16"
                                          VerticalOptions="Center"
                                          Margin="0,0,10,0" />

                                    <!-- Server Name -->
                                    <Label Grid.Column="1" Grid.Row="0"
                                          Text="{Binding Name}"
                                          FontSize="16"
                                          FontAttributes="Bold" />

                                    <!-- Server Status and Project Count -->
                                    <HorizontalStackLayout Grid.Column="1" Grid.Row="1" Spacing="10">
                                        <Label Text="{Binding StatusDisplay}"
                                              FontSize="12"
                                              TextColor="{Binding State, Converter={StaticResource StateToColorConverter}}" />
                                        <Label Text="{Binding ProjectCountDisplay}"
                                              FontSize="12"
                                              TextColor="Gray" />
                                        <!-- Profile name shown when "All" is selected -->
                                        <Label Text="{Binding ProfileName, StringFormat='({0})'}"
                                              FontSize="12"
                                              TextColor="Gray"
                                              IsVisible="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=IsAllProfilesSelected}" />
                                    </HorizontalStackLayout>

                                    <!-- Server Type Badge -->
                                    <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                                           Padding="8,4"
                                           BackgroundColor="#512BD4"
                                           StrokeThickness="0"
                                           VerticalOptions="Center"
                                           Margin="10,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Type}"
                                              TextColor="White"
                                              FontSize="10" />
                                    </Border>

                                    <!-- Server Actions -->
                                    <HorizontalStackLayout Grid.Column="3" Grid.Row="0" Grid.RowSpan="2"
                                                          Spacing="5" VerticalOptions="Center">
                                        <!-- Connection Status Indicator -->
                                        <Border WidthRequest="10"
                                               HeightRequest="10"
                                               StrokeThickness="0"
                                               VerticalOptions="Center">
                                            <Border.StrokeShape>
                                                <Ellipse />
                                            </Border.StrokeShape>
                                            <Border.BackgroundColor>
                                                <Binding Path="IsConnected">
                                                    <Binding.Converter>
                                                        <StaticResource Key="BoolToColorConverter" />
                                                    </Binding.Converter>
                                                </Binding>
                                            </Border.BackgroundColor>
                                        </Border>

                                        <!-- Start Button -->
                                        <Button Text="Start"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=StartServerCommand}"
                                               CommandParameter="{Binding .}"
                                               IsVisible="{Binding State, Converter={StaticResource StateToStartVisibilityConverter}}"
                                               HeightRequest="32"
                                               Padding="10,0"
                                               FontSize="12" />

                                        <!-- Stop Button -->
                                        <Button Text="Stop"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=StopServerCommand}"
                                               CommandParameter="{Binding .}"
                                               IsVisible="{Binding State, Converter={StaticResource StateToStopVisibilityConverter}}"
                                               HeightRequest="32"
                                               Padding="10,0"
                                               FontSize="12" />

                                        <!-- New Project Button -->
                                        <Button Text="+"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=CreateProjectCommand}"
                                               CommandParameter="{Binding .}"
                                               IsVisible="{Binding CanConnect}"
                                               HeightRequest="32"
                                               WidthRequest="32"
                                               Padding="0"
                                               FontSize="16" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>

                            <!-- Projects List (collapsible) -->
                            <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1C1C1C}">

                                <!-- Loading Indicator for Projects -->
                                <ActivityIndicator IsRunning="{Binding IsLoadingProjects}"
                                                 IsVisible="{Binding IsLoadingProjects}"
                                                 HorizontalOptions="Center"
                                                 Margin="10" />

                                <!-- Error Message -->
                                <Label Text="{Binding ErrorMessage}"
                                      IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                                      TextColor="Red"
                                      FontSize="12"
                                      Margin="15,5"
                                      HorizontalTextAlignment="Center" />

                                <!-- Projects -->
                                <CollectionView ItemsSource="{Binding Projects}"
                                               SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:ProjectSummary">
                                            <Border Padding="12,10"
                                                   Margin="15,2"
                                                   Stroke="{AppThemeBinding Light=LightGray, Dark=DarkGray}"
                                                   StrokeThickness="1"
                                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2C2C2C}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6" />
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=NavigateToProjectCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>

                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                                    <!-- Project Name -->
                                                    <Label Grid.Column="0" Grid.Row="0"
                                                          Text="{Binding Name}"
                                                          FontSize="14"
                                                          FontAttributes="Bold" />

                                                    <!-- Current Question (if any) -->
                                                    <Label Grid.Column="0" Grid.Row="1"
                                                          Text="{Binding CurrentQuestion}"
                                                          FontSize="11"
                                                          TextColor="Orange"
                                                          IsVisible="{Binding CurrentQuestion, Converter={StaticResource IsNotNullConverter}}"
                                                          LineBreakMode="TailTruncation"
                                                          MaxLines="1" />

                                                    <!-- Time -->
                                                    <Label Grid.Column="1" Grid.Row="0"
                                                          Text="{Binding UpdatedAt, StringFormat='{0:HH:mm}'}"
                                                          FontSize="11"
                                                          TextColor="Gray"
                                                          VerticalOptions="Start" />

                                                    <!-- State Badge -->
                                                    <Border Grid.Column="1" Grid.Row="1"
                                                           Padding="6,2"
                                                           BackgroundColor="{Binding State, Converter={StaticResource StateToColorConverter}}"
                                                           StrokeThickness="0"
                                                           VerticalOptions="Center"
                                                           HorizontalOptions="End">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="8" />
                                                        </Border.StrokeShape>
                                                        <Label Text="{Binding State}"
                                                              TextColor="White"
                                                              FontSize="9" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                    <CollectionView.EmptyView>
                                        <Label Text="No projects"
                                              FontSize="12"
                                              TextColor="Gray"
                                              HorizontalTextAlignment="Center"
                                              Margin="10"
                                              IsVisible="{Binding IsLoadingProjects, Converter={StaticResource InverseBoolConverter}}" />
                                    </CollectionView.EmptyView>
                                </CollectionView>

                                <!-- Bottom padding for the group -->
                                <BoxView HeightRequest="5" Color="Transparent" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="20">
                        <Label Text="No servers configured"
                              FontSize="18"
                              TextColor="Gray"
                              HorizontalTextAlignment="Center" />
                        <Label Text="Add a server to get started"
                              FontSize="14"
                              TextColor="Gray"
                              HorizontalTextAlignment="Center"
                              Margin="0,10,0,0" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!-- Error Message -->
        <Label Grid.Row="1"
              Text="{Binding ErrorMessage}"
              IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
              TextColor="Red"
              Padding="10"
              VerticalOptions="End"
              HorizontalOptions="Center" />
    </Grid>

</ContentPage>
