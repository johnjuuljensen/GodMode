<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>GodMode.AI.LocalInference.Mac</RootNamespace>
  </PropertyGroup>

  <!-- Mac: full build with CPU ONNX -->
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <!-- Non-Mac: stub build -->
  <PropertyGroup Condition="!$([MSBuild]::IsOSPlatform('OSX'))">
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <ProjectReference Include="..\GodMode.AI\GodMode.AI.csproj" />
    <PackageReference Include="Microsoft.ML.OnnxRuntimeGenAI" Version="0.12.1" />
    <PackageReference Include="Microsoft.Extensions.AI" Version="9.4.3-preview.1.25230.7" />
  </ItemGroup>

  <ItemGroup Condition="!$([MSBuild]::IsOSPlatform('OSX'))">
    <Compile Remove="**/*.cs" />
  </ItemGroup>

</Project>
